---
// 引入全局样式：Astro 会自动打包并注入，避免外部 link 在构建后 404
import '../styles/global.css';
import { getSiteUrl } from '../utils/site';

// 站点元数据与全局 SEO 配置
export interface SiteMeta {
  title: string;
  description: string;
  // ogImage 默认使用 /og-image.png（PNG 格式，主流社交平台兼容渲染）
  ogImage?: string;
  // canonical 默认自动拼接 Astro.url
  canonical?: string;
  // 是否禁止索引（如隐私政策页可设为 false）
  indexable?: boolean;
  // 分页 SEO 信号：指向上一页/下一页，帮助搜索引擎理解分页关系
  prevUrl?: string;
  nextUrl?: string;
  // 页面级 JSON-LD 结构化数据（如 WebApplication），与站点级 WebSite 合并输出
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const SITE_NAME = '工具盒子';
// 站点绝对 URL：集中化获取，未配置时构建直接报错（fail-fast），防止部署遗漏
const SITE_URL = getSiteUrl(Astro.site);

interface Props {
  meta: SiteMeta;
}

const { meta } = Astro.props;
const fullTitle = meta.title.includes(SITE_NAME)
  ? meta.title
  : `${meta.title} - ${SITE_NAME}`;
const canonical = meta.canonical ?? new URL(Astro.url.pathname, SITE_URL).toString();
const ogImage = meta.ogImage ?? new URL('/og-image.png', SITE_URL).toString();
const indexable = meta.indexable ?? true;

// 站点级 WebSite 结构化数据：所有页面共享，帮助搜索引擎理解站点
const siteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE_NAME,
  url: SITE_URL,
  description: '面向中文开发者的现代化在线工具集，全本地处理，零广告零追踪。',
  inLanguage: 'zh-CN',
};
// 合并站点级与页面级 JSON-LD，统一以数组形式输出
const pageLd = meta.jsonLd ? (Array.isArray(meta.jsonLd) ? meta.jsonLd : [meta.jsonLd]) : [];

// WebApplication url 自动注入：工具页的 JSON-LD 不再硬编码 url（BUG-36 已清理），
// 此处作为安全网——当 url 缺失时自动用 canonical 补充，仍指向占位域名时自动覆盖。
// 保留 PLACEHOLDER_ORIGIN 检测以防未来新增工具页误用占位域名。
const PLACEHOLDER_ORIGIN = 'https://toolbox.example.com';
const normalizedPageLd = pageLd.map((ld) => {
  if (
    ld &&
    typeof ld === 'object' &&
    (ld as Record<string, unknown>)['@type'] === 'WebApplication'
  ) {
    const url = (ld as Record<string, unknown>).url;
    if (!url || (typeof url === 'string' && url.startsWith(PLACEHOLDER_ORIGIN))) {
      return { ...ld, url: canonical };
    }
  }
  return ld;
});
const allLd = [siteLd, ...normalizedPageLd];
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={meta.description} />
    <link rel="canonical" href={canonical} />
    {meta.prevUrl && <link rel="prev" href={meta.prevUrl} />}
    {meta.nextUrl && <link rel="next" href={meta.nextUrl} />}
    {!indexable && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={meta.description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:locale" content="zh_CN" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={meta.description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- 图标 -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- RSS 订阅源：供阅读器与搜索引擎发现 -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title="工具盒子技术博客"
      href="/rss.xml"
    />

    <!-- 结构化数据：站点级 WebSite + 页面级 WebApplication，帮助搜索引擎理解 -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(allLd)} />
  </head>
  <body>
    <a href="#main" class="skip-link">跳到主要内容</a>
    <slot name="header">
      <header class="site-header">
        <div class="container site-header__inner">
          <a href="/" class="site-header__brand" aria-label="工具盒子首页">
            <span class="site-header__brand-mark" aria-hidden="true">工</span>
            <span>工具盒子</span>
          </a>
          <nav class="site-header__nav" aria-label="主导航">
            {/* aria-current 标记当前页面，配合 CSS 提供激活态视觉反馈 */}
            <a href="/" aria-current={Astro.url.pathname === '/' ? 'page' : undefined}>首页</a>
            <a href="/#tools-list" aria-current={Astro.url.pathname.startsWith('/json') || Astro.url.pathname.startsWith('/base') || Astro.url.pathname.startsWith('/hash') || Astro.url.pathname.startsWith('/jwt') || Astro.url.pathname.startsWith('/regex') ? 'page' : undefined}>工具</a>
            <a href="/blog" aria-current={Astro.url.pathname.startsWith('/blog') ? 'page' : undefined}>博客</a>
            <a href="/about" aria-current={Astro.url.pathname === '/about' ? 'page' : undefined}>关于</a>
          </nav>
        </div>
      </header>
    </slot>
    <main id="main">
      <slot />
    </main>
    <slot name="footer">
      <footer class="site-footer">
        <div class="container site-footer__inner">
          <div>
            © {new Date().getFullYear()} 工具盒子 · 全本地处理 · 零追踪
          </div>
          <nav aria-label="底部导航">
            <a href="/about">关于</a>
            &nbsp;·&nbsp;
            <a href="/privacy">隐私政策</a>
          </nav>
        </div>
      </footer>
    </slot>
  </body>
</html>
