<style is:global>
  /* 图片元数据打包工具专属样式：mdb 命名空间 */
  .mdb {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* 上传区 */
  .mdb__upload {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .mdb__dropzone {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 200px;
    padding: 32px 24px;
    border: 2px dashed var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-soft);
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    text-align: center;
    outline: none;
  }

  .mdb__dropzone:hover,
  .mdb__dropzone:focus-visible,
  .mdb__dropzone--over {
    border-color: var(--color-primary);
    background: var(--color-primary-soft);
    box-shadow: 0 0 0 3px var(--color-primary-ring);
  }

  .mdb__dropzone-icon {
    font-size: 40px;
    margin-bottom: 8px;
  }

  .mdb__dropzone-text {
    font-size: 16px;
    color: var(--color-text);
    margin-bottom: 4px;
  }

  .mdb__dropzone-hint {
    font-size: 12px;
    color: var(--color-text-soft, #6b7280);
  }

  .mdb__file-input {
    display: none;
  }

  /* 错误提示 */
  .mdb__error {
    padding: 12px 16px;
    background: rgba(231, 76, 60, 0.08);
    border: 1px solid rgba(231, 76, 60, 0.3);
    border-radius: var(--radius-sm);
    color: #c0392b;
    font-size: 13px;
  }

  .mdb__error pre {
    margin: 4px 0 0;
    white-space: pre-wrap;
    word-break: break-word;
    font-family: inherit;
    font-size: 12px;
  }

  /* 文件列表 */
  .mdb__files {
    padding: 16px;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .mdb__files-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 12px;
  }

  .mdb__files-title {
    margin: 0;
    font-size: 16px;
    font-weight: 600;
  }

  .mdb__count {
    color: var(--color-text-soft, #6b7280);
    font-weight: 400;
    font-size: 13px;
  }

  .mdb__files-actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .mdb__file-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
    max-height: 280px;
    overflow-y: auto;
  }

  .mdb__file-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 8px 12px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-size: 13px;
  }

  .mdb__file-name {
    flex: 1 1 auto;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .mdb__file-size {
    flex-shrink: 0;
    color: var(--color-text-soft, #6b7280);
    font-variant-numeric: tabular-nums;
  }

  .mdb__file-type {
    flex-shrink: 0;
    color: var(--color-text-soft, #6b7280);
    font-size: 12px;
