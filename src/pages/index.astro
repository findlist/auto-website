    desc: '在线 HTTP 状态码查询工具：覆盖 1xx / 2xx / 3xx / 4xx / 5xx 共 55+ 状态码，含详细说明、典型场景、常见原因、排查建议、RESTful API 用法、相关响应头与相关状态码对比。支持搜索、5 大类分类筛选、一键复制状态码，适用于前端调试接口错误、后端设计 RESTful API、SEO 重定向策略（301/302/307/308）、错误码定位（401/403/404/429/500/502/503/504）等场景。',
    badge: '可用',
    available: true,
    category: '网络',
    keywords: 'http 状态码 404 500 302 301 307 308 401 403 429 502 503 504 restful 重定向 seo 客户端错误 服务端错误',
  },
  {
    href: '/jsonpath',
    title: 'JSONPath 查询工具',
    desc: '在线 JSONPath 查询工具：基于 RFC 9535 标准实现的三阶段解析器（词法 / 语法 / 求值），支持 $ 根、.name 子节点、..name 递归下降、[*] 通配符、[index] 索引（含负索引）、[?(filter)] 过滤表达式（==/!=/>/>=/</<=/=~ 与 &&/||/! 组合），内置 12 个预设示例与电商订单 / 用户列表示例数据，查询结果展示索引、类型标签与单条复制，零依赖纯函数实现，适用于 API 响应提取、JSON 数据探查、配置筛选、自动化测试断言等场景。',
    badge: '可用',
    available: true,
    category: '编码转换',
    keywords: 'jsonpath json 路径 提取 查询 过滤 rfc 9535 递归 通配符 索引 jq 数据探查 api',
  },
  {
    href: '/json-schema',
    title: 'JSON Schema 校验',
    desc: '在线 JSON Schema 校验工具：基于 draft-07 标准自实现的轻量校验器，支持 type/required/properties/items/enum/const/数值范围/字符串长度与 pattern 与 format/数组 uniqueItems/对象 additionalProperties/allOf/anyOf/oneOf/not/$ref 内部引用等核心关键字。实时校验、错误路径精确定位、关键字分类徽章、中文错误消息，零依赖纯 TS 实现（约 14KB），适用于 API 请求体校验、配置文件验证、表单数据校验、OpenAPI/Swagger schema 验证等场景。',
    badge: '可用',
    available: true,
    category: '编码转换',
    keywords: 'json schema 校验 draft-07 validator 验证 type required properties items enum const minimum maximum pattern format $ref allof anyof oneof uniqueitems additionalproperties openapi swagger',
  },
  {
    href: '/yaml-schema',
    title: 'YAML Schema 校验',
    desc: '在线 YAML Schema 校验工具：用 JSON Schema（draft-07）校验 YAML 数据，复用轻量校验引擎，覆盖 type/required/properties/items/enum/数值范围/字符串 pattern 与 format/数组 uniqueItems/$ref 等核心关键字。额外检测 YAML 类型推断陷阱（yes/no/on/off 布尔化、版本号被解析为数字等），适用于 Kubernetes 清单（Deployment/Service/Pod）、CI/CD 配置（GitHub Actions/GitLab CI）、Helm values、docker-compose 等场景。实时校验、错误路径定位、关键字分类徽章，全部本地处理。',
    badge: '可用',
    available: true,
    category: '编码转换',
    keywords: 'yaml schema 校验 json schema k8s kubernetes deployment 清单 配置 ci cd github actions gitlab helm docker-compose 类型推断 陷阱 yes no on off 布尔',
  },
  {
    href: '/toml-schema',
    title: 'TOML Schema 校验',
    desc: '在线 TOML Schema 校验工具：用 JSON Schema（draft-07）校验 TOML 数据，复用轻量校验引擎，覆盖 type/required/properties/items/enum/数值范围/字符串 pattern 与 format/数组 uniqueItems/$ref 等核心关键字。额外检测 TOML 类型陷阱（日期时间值转 JSON 丢失类型信息、64 位整数超过 Number.MAX_SAFE_INTEGER 丢失精度），适用于 pyproject.toml（PEP 621）、Cargo.toml、rust-toolchain.toml、renovate.json 等场景。实时校验、错误路径定位、关键字分类徽章，全部本地处理。',
    badge: '可用',
    available: true,
    category: '编码转换',
    keywords: 'toml schema 校验 json schema pyproject cargo pep 621 rust-toolchain renovate 类型陷阱 日期时间 大整数 精度 丢失',
  },
  {
    href: '/regex-benchmark',
    title: '正则表达式性能基准',
    desc: '在线正则表达式性能基准测试工具：执行 N 次匹配统计平均/最大/最小/标准差耗时，静态分析检测嵌套量词、重叠分支、通配量词三类 ReDoS 危险模式，渐进式压力测试用递增长度输入判断是否指数级回溯。内置经典 ReDoS 示例 (a+)+ 与安全正则示例，适用于上线前正则性能审计、ReDoS 漏洞排查、正则优化效果对比等场景。',
    badge: '可用',
    available: true,
    category: '代码调试',
    keywords: '正则 regex 性能 基准 测试 redos 拒绝服务 回溯 嵌套量词 重叠分支 通配 压力测试 指数增长 安全',
  },
];

// 工具分类列表（去重），用于分类筛选按钮
const categories = ['全部', ...Array.from(new Set(tools.map((t) => t.category)))];

// 站点绝对 URL：用于结构化数据中的 url 字段（集中化获取，未配置时构建报错）
const SITE_URL = getSiteUrl(Astro.site);

// Organization 结构化数据：站点运营方实体，帮助搜索引擎建立品牌识别
const organizationLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: '工具盒子',
  url: SITE_URL,
  logo: `${SITE_URL}/favicon.svg`,
  description: '面向中文开发者的现代化在线工具集，全本地处理，零广告零追踪。',
};

// ItemList 结构化数据：工具集合矩阵，帮助搜索引擎识别站点为工具聚合站
const itemListLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: '工具盒子在线工具集合',
  description: `${tools.length} 个面向中文开发者的在线工具：编码转换、加密哈希、时间日期、代码调试、网络计算、设计、文档处理等场景。`,
  numberOfItems: tools.length,
  itemListElement: tools.map((t, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: t.title,
    url: `${SITE_URL}${t.href}`,
    description: t.desc,
  })),
};

// 注入首页结构化数据，BaseLayout 会与站点级 WebSite JSON-LD 合并输出
meta.jsonLd = [organizationLd, itemListLd];

// 特色卖点
const features = [
  {
    title: '零广告 · 零追踪',
    desc: '不嵌入任何广告与统计脚本，没有弹窗干扰，专注于工具本身。',
    icon: '🚫',
  },
  {
    title: '全本地处理',
    desc: '所有计算在浏览器内完成，数据不离开你的设备，敏感信息更安全。',
    icon: '🔒',
  },
  {
    title: '现代化体验',
    desc: '响应式布局、键盘友好、暗色模式、复制即用，桌面与移动端一致。',
    icon: '⚡',
  },
];
---
<BaseLayout meta={meta}>
  <!-- Hero -->
  <section class="hero">
    <div class="container hero__inner">
      <h1>干净 · 高效 · 不打扰的<br /><span class="hero__accent">中文开发者在线工具集</span></h1>
      <p class="hero__lead">
        告别广告满天飞的老工具站。JSON、Base64、JWT、正则、时间戳、UUID 等 47 个工具，全部在浏览器本地处理，秒开、零上传、零追踪。
      </p>
      <div class="hero__cta">
        <a class="btn btn--primary" href="/json/">立即使用 JSON 工具</a>
        <a class="btn" href="#features">了解特色</a>
      </div>
    </div>
  </section>

  <!-- 工具卡片 -->
  <section id="tools-list" class="container tools" aria-labelledby="tools-title">
    <h2 id="tools-title" class="section-title">工具列表</h2>

    <!-- 搜索与分类筛选 -->
    <div class="tools__toolbar">
      <label class="tools__search">
        <span class="visually-hidden">搜索工具</span>
        <input
          type="search"
          id="tools-search"
          placeholder="搜索工具名称或功能…"
          autocomplete="off"
          aria-controls="tools-grid"
        />
      </label>
      <div class="tools__filters" role="group" aria-label="按分类筛选工具">
        {categories.map((cat, i) => (
          <button
            type="button"
            class={`tools__filter${i === 0 ? ' tools__filter--active' : ''}`}
            data-category={cat}
            aria-pressed={i === 0 ? 'true' : 'false'}
          >{cat}</button>
        ))}
      </div>
    </div>

    <ul id="tools-grid" class="tools__grid" role="list">
      {tools.map((t) => (
        <li
          class={`tool-card${t.available ? '' : ' tool-card--soon'}`}
          data-category={t.category}
          data-keywords={t.keywords}
          data-title={t.title}
        >
          {t.available ? (
            <a href={t.href} class="tool-card__link">
              <span class="tool-card__title">{t.title}</span>
              <span class="tool-card__desc">{t.desc}</span>
              <span class="tool-card__badge">{t.badge}</span>
            </a>
          ) : (
            <div class="tool-card__link" aria-disabled="true">
              <span class="tool-card__title">{t.title}</span>
              <span class="tool-card__desc">{t.desc}</span>
              <span class="tool-card__badge tool-card__badge--soon">{t.badge}</span>
            </div>
          )}
        </li>
      ))}
    </ul>

    <!-- 空状态：无匹配工具时显示 -->
    <p class="tools__empty" id="tools-empty" hidden>没有找到匹配的工具，试试其他关键词或分类。</p>
  </section>

  <!-- 工具筛选逻辑：原生实现，不引入框架，不增加 JS bundle（Astro 内联打包） -->
  <script>
    const searchInput = document.getElementById('tools-search') as HTMLInputElement | null;
    const grid = document.getElementById('tools-grid');
    const empty = document.getElementById('tools-empty');
    const filterButtons = document.querySelectorAll('.tools__filter');

    if (searchInput && grid) {
      let activeCategory = '全部';
      let query = '';

      // 根据当前分类与搜索词过滤工具卡片
      const applyFilter = () => {
        const cards = grid.querySelectorAll<HTMLElement>('.tool-card');
        let visibleCount = 0;
        cards.forEach((card) => {
          const cat = card.getAttribute('data-category') || '';
          const title = (card.getAttribute('data-title') || '').toLowerCase();
          const keywords = (card.getAttribute('data-keywords') || '').toLowerCase();
          const matchCategory = activeCategory === '全部' || cat === activeCategory;
          const matchQuery = !query || title.includes(query) || keywords.includes(query);
          const show = matchCategory && matchQuery;
          card.style.display = show ? '' : 'none';
          if (show) visibleCount += 1;
        });
        if (empty) empty.hidden = visibleCount !== 0;
      };

      // 搜索输入：实时过滤
      searchInput.addEventListener('input', () => {
        query = searchInput.value.trim().toLowerCase();
        applyFilter();
      });

      // 分类按钮：切换激活态并重新过滤
      filterButtons.forEach((btn) => {
        btn.addEventListener('click', () => {
          filterButtons.forEach((b) => {
            b.classList.remove('tools__filter--active');
            b.setAttribute('aria-pressed', 'false');
          });
          btn.classList.add('tools__filter--active');
          btn.setAttribute('aria-pressed', 'true');
          activeCategory = btn.getAttribute('data-category') || '全部';
          applyFilter();
        });
      });
    }
  </script>

  <!-- 特色 -->
  <section id="features" class="container features" aria-labelledby="features-title">
    <h2 id="features-title" class="section-title">为什么选工具盒子</h2>
    <ul class="features__grid" role="list">
      {features.map((f) => (
        <li class="feature">
          <span class="feature__icon" aria-hidden="true">{f.icon}</span>
          <h3 class="feature__title">{f.title}</h3>
          <p class="feature__desc">{f.desc}</p>
        </li>
      ))}
    </ul>
  </section>

  <!-- 最新文章 -->
  <section id="blog" class="container blog-section" aria-labelledby="blog-title">
    <div class="blog-section__head">
      <h2 id="blog-title" class="section-title">技术博客</h2>
      <a href="/blog" class="blog-section__more">查看全部 →</a>
    </div>
    <ul class="blog-section__grid" role="list">
      {recentPosts.map((post) => (
        <li class="blog-section__card">
          <h3 class="blog-section__card-title">
            <a href={`/blog/${post.id}`} class="blog-section__link">{post.data.title}</a>
          </h3>
          <p class="blog-section__card-desc">{post.data.description}</p>
          <div class="blog-section__meta">
            <time class="blog-section__date" datetime={post.data.pubDate.toISOString()}>
              {formatDate(post.data.pubDate)}
            </time>
            {post.data.tags.length > 0 && (
              <span class="blog-section__tags">
                {post.data.tags.slice(0, 2).map((tag) => (
                  <a href={`/blog/tag/${tagToSlug(tag)}`} class="blog-section__tag">#{tag}</a>
                ))}
              </span>
            )}
          </div>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 72px 0 48px;
    text-align: center;
    background:
      radial-gradient(1200px 400px at 50% -10%, rgba(43, 108, 255, 0.12), transparent 60%),
      radial-gradient(800px 300px at 80% 20%, rgba(122, 76, 255, 0.06), transparent 60%);
  }

  .hero__inner h1 {
    font-size: 42px;
    line-height: 1.2;
    margin: 0 auto 16px;
    max-width: 720px;
    letter-spacing: -0.02em;
    font-weight: 700;
  }

  .hero__accent {
    background: linear-gradient(120deg, var(--color-primary), var(--color-accent));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .hero__lead {
    max-width: 580px;
    margin: 0 auto 28px;
    color: var(--color-text-soft);
    font-size: 17px;
    line-height: 1.7;
  }

  .hero__cta {
    display: inline-flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .section-title {
    font-size: 22px;
    font-weight: 600;
    margin: 0 0 20px;
    letter-spacing: -0.01em;
  }

  .tools {
    padding-top: 24px;
  }

  /* 工具搜索与分类筛选工具栏 */
  .tools__toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }

  .tools__search {
    flex: 1;
    min-width: 240px;
  }

  .tools__search input {
    width: 100%;
    padding: 10px 14px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    color: var(--color-text);
    font-size: 14px;
    font-family: inherit;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .tools__search input:focus-visible {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px var(--color-primary-ring);
  }

  .tools__filters {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tools__filter {
    padding: 7px 14px;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-bg);
    color: var(--color-text-soft);
    font-size: 13px;
    font-family: inherit;
    cursor: pointer;
    transition: border-color var(--transition-fast), color var(--transition-fast),
      background-color var(--transition-fast);
  }

  .tools__filter:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .tools__filter--active {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: #fff;
    box-shadow: 0 2px 6px var(--color-primary-ring);
  }

  .tools__empty {
    text-align: center;
    color: var(--color-text-muted);
    padding: 32px 16px;
    font-size: 14px;
  }

  /* 无障碍：视觉隐藏但屏幕阅读器可见 */
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .tools__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 16px;
  }

  .tool-card {
    position: relative;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    box-shadow: var(--shadow-sm);
    transition: border-color var(--transition-base), box-shadow var(--transition-base),
      transform var(--transition-base);
    overflow: hidden;
  }

  /* 悬停时左侧出现主色指示条，增强视觉反馈 */
  .tool-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: linear-gradient(180deg, var(--color-primary), var(--color-accent));
    transform: scaleY(0);
    transform-origin: top;
    transition: transform var(--transition-base);
  }

  .tool-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }

  .tool-card:hover::before {
    transform: scaleY(1);
  }

  .tool-card--soon:hover {
    border-color: var(--color-border);
    transform: none;
    box-shadow: var(--shadow-sm);
  }

  .tool-card--soon:hover::before {
    transform: scaleY(0);
  }

  .tool-card__link {
    display: block;
    padding: 20px;
    color: inherit;
    position: relative;
  }

  .tool-card__title {
    display: block;
    font-size: 17px;
    font-weight: 600;
    margin-bottom: 6px;
  }

  .tool-card__desc {
    display: block;
    color: var(--color-text-soft);
    font-size: 14px;
    line-height: 1.6;
  }

  .tool-card__badge {
    display: inline-block;
    margin-top: 12px;
    padding: 2px 8px;
    font-size: 12px;
    border-radius: 999px;
    background: var(--color-success-soft);
    color: var(--color-success);
    font-weight: 500;
  }

  .tool-card__badge--soon {
    background: var(--color-bg-soft);
    color: var(--color-text-muted);
  }

  .features {
    padding-top: 56px;
  }

  .features__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }

  .feature {
    padding: 24px;
    border-radius: var(--radius-md);
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    transition: border-color var(--transition-base), box-shadow var(--transition-base),
      transform var(--transition-base);
  }

  .feature:hover {
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-sm);
    transform: translateY(-2px);
  }

  .feature__icon {
    font-size: 28px;
    line-height: 1;
  }

  .feature__title {
    margin: 12px 0 8px;
    font-size: 17px;
    font-weight: 600;
  }

  .feature__desc {
    margin: 0;
    color: var(--color-text-soft);
    font-size: 14px;
    line-height: 1.7;
  }

  /* 最新文章模块 */
  .blog-section {
    padding-top: 56px;
  }

  .blog-section__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 20px;
  }

  .blog-section__more {
    font-size: 14px;
    font-weight: 500;
  }

  .blog-section__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
  }

  .blog-section__card {
    position: relative;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    box-shadow: var(--shadow-sm);
    transition: border-color var(--transition-base), box-shadow var(--transition-base),
      transform var(--transition-base);
    overflow: hidden;
    padding: 20px;
  }

  .blog-section__card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }

  /* 拉伸链接：标题链接撑满整张卡片 */
  .blog-section__link {
    color: inherit;
    text-decoration: none;
  }

  .blog-section__link::after {
    content: '';
    position: absolute;
    inset: 0;
  }

  .blog-section__card-title {
    margin: 0 0 8px;
    font-size: 16px;
    font-weight: 600;
    line-height: 1.4;
  }

