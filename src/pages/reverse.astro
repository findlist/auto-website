---
import BaseLayout, { type SiteMeta } from '../layouts/BaseLayout.astro';
import ReverseTool from '../components/ReverseTool.tsx';

const meta: SiteMeta = {
  title: '文本反转工具 - 字符 / 行 / 单词反转',
  description:
    '免费的在线文本反转工具：支持字符反转（整段文本字符顺序反转）、行反转（行顺序反转）、单词反转（每行内单词顺序反转）三种模式，可选反转大小写、去除空行。使用 Unicode 安全的 Array.from 处理，正确支持 Emoji 和代理对。适用于文本加密混淆、回文检测辅助、数据顺序调整、创意文案生成等场景。所有处理在浏览器本地完成，零上传、零追踪、零广告。',
  jsonLd: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: '文本反转工具',
    description: '在线文本反转工具，支持字符反转、行反转、单词反转三种模式，Unicode 安全，正确处理 Emoji。',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Any (Web Browser)',
    inLanguage: 'zh-CN',
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'CNY',
    },
  },
};
---
<BaseLayout meta={meta}>
  <section class="container">
    <div class="page-hero page-hero--tool">
      <h1>文本反转工具</h1>
      <p>
        支持三种反转模式：字符反转（整段文本字符顺序反转）、行反转（行顺序反转，每行内容不变）、
        单词反转（每行内单词顺序反转）。可选反转大小写、去除空行。使用 Unicode 安全处理，
        正确支持 Emoji 和代理对。适用于文本加密混淆、回文检测、数据顺序调整、创意文案等场景。所有处理在浏览器本地完成。
      </p>
    </div>

    <ReverseTool client:load />

    <section class="json-faq" aria-labelledby="faq-title">
      <h2 id="faq-title">常见问题</h2>
      <details>
        <summary>字符反转、行反转和单词反转有什么区别？</summary>
        <p>
          以输入 "Hello World\nFoo Bar"（两行）为例：
          <br />
          <strong>字符反转</strong>：整个文本视为字符序列反转，结果为 "raB ooF\ndlroW olleH"（换行符也被反转位置）。
          <br />
          <strong>行反转</strong>：行顺序反转，每行内容不变，结果为 "Foo Bar\nHello World"。
          <br />
          <strong>单词反转</strong>：每行内单词顺序反转，行结构保留，结果为 "World Hello\nBar Foo"。
        </p>
      </details>
      <details>
        <summary>为什么字符反转要用 Array.from 而不是 split('')？</summary>
        <p>
          JavaScript 中字符串的 <code>split('')</code> 按 UTF-16 码元分割，对于超出 BMP 平面的字符
          （如 Emoji 😀、部分生僻字）会将其拆分为两个代理对码元，反转后重组会得到乱码。
          <code>Array.from()</code> 会正确按 Unicode 码点遍历字符串，将每个完整字符（包括代理对）作为一个数组元素，
          反转后重组才能得到正确结果。这是处理 Unicode 文本的常见陷阱。
        </p>
      </details>
      <details>
        <summary>反转大小写是什么效果？</summary>
        <p>
          反转大小写会将文本中每个英文字母的大小写翻转：大写变小写、小写变大写。
          例如 "Hello World" → "hELLO wORLD"。该选项可与任意反转模式组合使用，
          常用于创意文案生成或简单的文本混淆。注意：仅对英文字母生效，中文和数字不受影响。
        </p>
      </details>
      <details>
        <summary>去除空行选项有什么作用？</summary>
        <p>
          输入文本可能包含空行（仅含空格或完全为空的行）。勾选"去除空行"后，
          反转处理前会先过滤掉所有空行，使结果更紧凑。对于行反转和单词反转模式，
          去除空行可以避免结果中出现多余的空行。字符反转模式下去除空行会让连续文本更紧凑。
        </p>
      </details>
      <details>
        <summary>这个工具适合哪些使用场景？</summary>
        <p>
          ① <strong>文本加密/混淆</strong>：简单地将文本反转，用于轻度隐藏内容；
          ② <strong>回文检测辅助</strong>：反转后与原文对比可判断是否为回文；
          ③ <strong>数据顺序调整</strong>：将列表倒序排列（行反转）；
          ④ <strong>创意文案生成</strong>：反转单词顺序产生特殊效果；
          ⑤ <strong>调试与测试</strong>：生成测试用的反转字符串，验证程序的字符串处理能力。
        </p>
      </details>
      <details>
        <summary>换行符在反转后会如何处理？</summary>
        <p>
          <strong>字符反转</strong>：换行符（\n）作为普通字符参与反转，位置会改变。
          <br />
          <strong>行反转 / 单词反转</strong>：换行符作为行分隔符，反转后行与行之间统一使用 \n 连接。
          如果输入使用 \r\n（Windows 换行符），反转后会统一为 \n。
        </p>
      </details>
      <details>
        <summary>数据会上传到服务器吗？</summary>
        <p>
          不会。本工具完全在浏览器内运行，所有反转操作由 JavaScript 在你本地执行，
          不会发送任何输入文本或反转结果到服务器。全程零网络请求，可离线使用。
        </p>
      </details>
    </section>
  </section>
</BaseLayout>

<style is:global>
  /* 文本反转工具专属样式 */
  .revtool {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .revtool__input-section {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .revtool__toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }

  .revtool__label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text);
  }

  .revtool__stat {
    font-size: 13px;
    font-weight: 400;
    color: var(--color-text-soft);
  }

  .revtool__actions {
    display: flex;
    gap: 8px;
  }

  .revtool__textarea {
    width: 100%;
    min-height: 120px;
    max-height: 300px;
    padding: 14px 16px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 14px;
    line-height: 1.6;
    resize: vertical;
    transition: border-color var(--transition-fast, 0.15s);
  }

  .revtool__textarea:focus {
    outline: none;
    border-color: var(--color-primary, #2b6cff);
    box-shadow: var(--focus-ring, 0 0 0 3px rgba(43, 108, 255, 0.15));
  }

  /* 选项区 */
  .revtool__options {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: 16px 24px;
    padding: 16px 18px;
    background: var(--color-bg-soft, rgba(0, 0, 0, 0.03));
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .revtool__option-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .revtool__option-label {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text);
  }

  /* 分段选择按钮 */
  .revtool__seg {
    display: inline-flex;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  .revtool__seg-btn {
    padding: 6px 14px;
    border: none;
    background: var(--color-bg);
    color: var(--color-text);
    font-size: 13px;
    cursor: pointer;
    transition: background var(--transition-fast, 0.15s);
  }

  .revtool__seg-btn:not(:last-child) {
    border-right: 1px solid var(--color-border);
  }

  .revtool__seg-btn.is-active {
    background: var(--color-primary, #2b6cff);
    color: #fff;
  }

  /* 复选框 */
  .revtool__check {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--color-text);
    cursor: pointer;
    padding-bottom: 4px;
  }

  .revtool__check input {
    width: 16px;
    height: 16px;
    accent-color: var(--color-primary, #2b6cff);
  }

  /* 结果区 */
  .revtool__result {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 14px 16px;
    background: var(--color-bg-soft, rgba(0, 0, 0, 0.03));
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .revtool__result-header {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .revtool__result-label {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text);
  }

  .revtool__copy {
    margin-left: auto;
  }

  .revtool__result-value {
    font-family: var(--font-mono);
    font-size: 15px;
    color: var(--color-text);
    white-space: pre-wrap;
    word-break: break-all;
    line-height: 1.5;
    min-height: 24px;
    padding: 10px 12px;
    background: var(--color-bg);
    border-radius: var(--radius-sm);
  }

  .revtool__result-empty {
    color: var(--color-text-soft);
    font-style: italic;
  }

  /* 状态条 */
  .revtool__status {
    min-height: 24px;
    font-size: 14px;
  }

  .revtool__notice {
    padding: 10px 14px;
    background: var(--color-success-soft, rgba(26, 170, 85, 0.08));
    border-radius: var(--radius-sm);
    color: var(--color-success, #1aaa55);
  }

  .revtool__hint {
    padding: 10px 14px;
    color: var(--color-text-soft);
  }

  /* 暗色模式适配 */
  @media (prefers-color-scheme: dark) {
    .revtool__options,
    .revtool__result,
    .revtool__textarea {
      background: rgba(255, 255, 255, 0.04);
    }
    .revtool__result-value {
      background: rgba(0, 0, 0, 0.2);
    }
    .revtool__seg-btn {
      background: rgba(255, 255, 255, 0.06);
    }
  }

  /* 移动端响应式 */
  @media (max-width: 414px) {
    .revtool__toolbar {
      flex-direction: column;
      align-items: stretch;
    }
    .revtool__actions {
      justify-content: flex-end;
    }
    .revtool__options {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
