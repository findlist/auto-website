  }

  .imgcmp__btn--primary:hover:not(:disabled) {
    background: var(--color-primary-hover);
    border-color: var(--color-primary-hover);
    color: #fff;
  }

  .imgcmp__btn--small {
    padding: 4px 10px;
    min-height: 28px;
    font-size: 12px;
  }

  .imgcmp__btn--danger {
    border-color: rgba(231, 76, 60, 0.3);
    color: #c0392b;
  }

  .imgcmp__btn--danger:hover:not(:disabled) {
    border-color: #e74c3c;
    background: rgba(231, 76, 60, 0.06);
    color: #c0392b;
  }

  /* ZIP 打包错误提示：与操作按钮同区域，醒目但不抢主操作焦点 */
  .imgcmp__batch-zip-error {
    display: inline-flex;
    align-items: center;
    padding: 6px 12px;
    min-height: 36px;
    font-size: 13px;
    color: #c0392b;
    background: rgba(231, 76, 60, 0.08);
    border: 1px solid rgba(231, 76, 60, 0.25);
    border-radius: var(--radius-md);
  }

  /* 结果展示区 */
  .imgcmp__result {
    position: relative;
    min-height: 100px;
  }

  .imgcmp__loading {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 20px;
    color: var(--color-text-soft);
    font-size: 14px;
  }

  .imgcmp__spinner {
    width: 16px;
    height: 16px;
    border: 2px solid var(--color-border);
    border-top-color: var(--color-primary);
    border-radius: 50%;
    animation: imgcmp-spin 0.8s linear infinite;
  }

  @keyframes imgcmp-spin {
    to { transform: rotate(360deg); }
  }

  /* 预览图 */
  .imgcmp__preview {
    padding: 16px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-soft);
    text-align: center;
    overflow-x: auto;
  }

  .imgcmp__preview-img {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-sm, 4px);
    background: var(--color-bg);
  }

  /* 滑块叠加模式 */
  .imgcmp__slider {
    position: relative;
    width: 100%;
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-soft);
    cursor: ew-resize;
    user-select: none;
    touch-action: none;
  }

  .imgcmp__slider:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
  }

  .imgcmp__slider-img {
    display: block;
    width: 100%;
    height: auto;
    pointer-events: none;
    -webkit-user-drag: none;
    user-drag: none;
  }

  .imgcmp__slider-img--bottom {
    position: static;
  }

  .imgcmp__slider-clip {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    overflow: hidden;
    pointer-events: none;
  }

  .imgcmp__slider-img--top {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: auto;
    max-width: none;
  }

  /* 滑块分隔线与把手 */
  .imgcmp__slider-divider {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 2px;
    background: #2b6cff;
    transform: translateX(-1px);
    pointer-events: none;
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.5);
  }

  .imgcmp__slider-handle {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #2b6cff;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    font-weight: bold;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  /* A/B 标签 */
  .imgcmp__slider-label {
    position: absolute;
    top: 8px;
    padding: 4px 10px;
    background: rgba(0, 0, 0, 0.6);
    color: #fff;
    font-size: 12px;
    font-weight: 600;
    border-radius: var(--radius-sm, 4px);
    pointer-events: none;
  }

  .imgcmp__slider-label--left {
    left: 8px;
  }

  .imgcmp__slider-label--right {
    right: 8px;
  }

  /* 差异统计 */
  .imgcmp__stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 12px;
    margin-top: 16px;
    padding: 16px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-soft);
  }

  .imgcmp__stat-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .imgcmp__stat-label {
    font-size: 12px;
    color: var(--color-text-soft);
  }

  .imgcmp__stat-value {
    font-size: 18px;
    font-weight: 600;
    color: var(--color-text);
    display: flex;
    align-items: baseline;
    gap: 6px;
    flex-wrap: wrap;
  }

  .imgcmp__stat-value--good {
    color: #27ae60;
  }

  .imgcmp__stat-value--warn {
    color: #e67e22;
  }

  .imgcmp__stat-value--bad {
    color: #c0392b;
  }

  .imgcmp__stat-level {
    font-size: 13px;
    font-weight: 500;
    opacity: 0.8;
  }

  /* ===== 差异区域框选与列表（增强能力） ===== */

  /* 差异图预览容器：相对定位，作为 SVG 叠加层的参照 */
  .imgcmp__preview--diff {
    position: relative;
    display: inline-block;
    max-width: 100%;
  }

  /* SVG 区域叠加层：与差异图同尺寸，绝对定位覆盖 */
  .imgcmp__regions-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  /* 单个区域分组：可点击（pointer-events: auto 接收事件） */
  .imgcmp__region-group {
    cursor: pointer;
    pointer-events: auto;
  }

  /* 区域包围盒矩形：默认黄色半透明，与红色差异像素形成对比 */
  .imgcmp__region-rect {
    fill: rgba(52, 152, 219, 0.12);
    stroke: rgba(52, 152, 219, 0.9);
    stroke-width: 1.5;
    transition: fill 0.15s, stroke-width 0.15s;
  }

  .imgcmp__region-group:hover .imgcmp__region-rect {
    fill: rgba(52, 152, 219, 0.25);
    stroke-width: 2.5;
  }

  /* 选中状态：红色加粗，与差异像素颜色呼应 */
  .imgcmp__region-group--active .imgcmp__region-rect {
    fill: rgba(231, 76, 60, 0.25);
    stroke: rgba(231, 76, 60, 1);
    stroke-width: 3;
  }

  /* 序号标签背景 */
  .imgcmp__region-label-bg {
    fill: rgba(52, 152, 219, 0.95);
    stroke: none;
  }

  .imgcmp__region-group--active .imgcmp__region-label-bg {
    fill: rgba(231, 76, 60, 0.95);
  }

  /* 序号文本 */
  .imgcmp__region-label-text {
    fill: #fff;
    font-size: 11px;
    font-weight: 700;
    font-family: ui-monospace, "SFMono-Regular", Menlo, Monaco, Consolas, monospace;
    pointer-events: none;
    user-select: none;
  }

  /* 区域框选显示开关 */
  .imgcmp__regions-toggle {
    position: absolute;
    bottom: 8px;
    left: 8px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 10px;
    background: rgba(0, 0, 0, 0.65);
    color: #fff;
    font-size: 12px;
    border-radius: var(--radius-sm, 4px);
    cursor: pointer;
    user-select: none;
  }

  .imgcmp__regions-toggle input {
    margin: 0;
    cursor: pointer;
  }

  /* 差异区域列表容器 */
  .imgcmp__regions {
    margin-top: 16px;
    padding: 16px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-soft);
  }

  .imgcmp__regions-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }

  .imgcmp__regions-title {
    margin: 0;
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text);
  }

  .imgcmp__regions-meta {
    font-size: 12px;
    color: var(--color-text-soft);
  }

  .imgcmp__regions-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
    max-height: 360px;
    overflow-y: auto;
  }

  .imgcmp__region-item {
    margin: 0;
    display: flex;
    align-items: stretch;
    gap: 6px;
  }

  .imgcmp__region-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    flex: 1;
    min-width: 0;
    padding: 8px 12px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm, 4px);
    background: var(--color-bg);
    color: var(--color-text);
    font-size: 13px;
    text-align: left;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    min-height: 44px;  /* WCAG 2.2 触控目标 */
  }

  /* 放大按钮：紧凑、固定宽度，与区域按钮并列 */
  .imgcmp__region-zoom {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 0 12px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm, 4px);
    background: var(--color-bg);
    color: var(--color-text-soft);
    font-size: 12px;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s, color 0.15s;
    min-height: 44px;
    white-space: nowrap;
  }

  .imgcmp__region-zoom:hover {
    border-color: #c0392b;
    color: #c0392b;
    background: rgba(231, 76, 60, 0.06);
  }

  .imgcmp__region-zoom:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring, 0 0 0 3px var(--color-primary-ring));
  }

  .imgcmp__region-btn:hover {
    border-color: var(--color-primary);
    background: var(--color-primary-soft);
  }

  .imgcmp__region-btn:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring, 0 0 0 3px var(--color-primary-ring));
  }

  .imgcmp__region-item--active .imgcmp__region-btn {
    border-color: #c0392b;
    background: rgba(231, 76, 60, 0.08);
  }

  /* 区域序号徽章 */
  .imgcmp__region-index {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    background: #3498db;
    color: #fff;
    font-size: 12px;
    font-weight: 700;
    border-radius: 50%;
    font-family: ui-monospace, "SFMono-Regular", Menlo, Monaco, Consolas, monospace;
  }

  .imgcmp__region-item--active .imgcmp__region-index {
    background: #c0392b;
  }

  /* 坐标信息 */
  .imgcmp__region-coord {
    flex-shrink: 0;
    font-family: ui-monospace, "SFMono-Regular", Menlo, Monaco, Consolas, monospace;
    font-size: 12px;
    color: var(--color-text-soft);
  }

  /* 统计信息组 */
  .imgcmp__region-stats {
    display: flex;
    gap: 10px;
    margin-left: auto;
    flex-wrap: wrap;
  }

  .imgcmp__region-pixels,
  .imgcmp__region-density,
  .imgcmp__region-intensity {
    font-size: 12px;
    color: var(--color-text-soft);
  }

  .imgcmp__region-pixels {
    color: var(--color-text);
    font-weight: 500;
  }

  /* 空状态 */
  .imgcmp__empty {
    padding: 24px;
    text-align: center;
    color: var(--color-text-soft);
    font-size: 14px;
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-md);
  }

  /* 移动端响应式 */
  @media (max-width: 768px) {
    .imgcmp__uploads {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .imgcmp__slot {
      min-height: 180px;
    }

    .imgcmp__mode-tab {
      padding: 6px 8px;
      font-size: 13px;
    }

    .imgcmp__actions {
      flex-direction: column;
    }

    .imgcmp__btn {
      width: 100%;
    }

    /* 错误提示在移动端占满整行，保持与按钮对齐 */
    .imgcmp__batch-zip-error {
      width: 100%;
      justify-content: center;
    }

    /* 配对模式提示在窄屏占满整行，避免挤压按钮 */
    .imgcmp__pair-mode-hint {
      flex: 1 1 100%;
      min-width: 0;
      margin-top: 2px;
    }

    .imgcmp__stats {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
      padding: 12px;
    }

    .imgcmp__stat-value {
      font-size: 16px;
    }

    .imgcmp__slider-handle {
      width: 32px;
      height: 32px;
      font-size: 14px;
    }

    /* 区域列表项在窄屏下统计信息换行 */
    .imgcmp__region-btn {
      flex-wrap: wrap;
    }

    .imgcmp__region-stats {
      width: 100%;
      margin-left: 0;
      gap: 8px;
    }
  }

  @media (max-width: 480px) {
    .imgcmp__stats {
      grid-template-columns: 1fr;
    }

    .imgcmp__slot-actions {
      flex-direction: column;
    }

    .imgcmp__btn--small {
      width: 100%;
    }

    /* 区域列表项在超窄屏下坐标独占一行 */
    .imgcmp__region-coord {
      width: 100%;
    }
  }

  /* 暗色模式适配 */
  :global([data-theme="dark"]) .imgcmp__error,
  :global([data-theme="dark"]) .imgcmp__notice {
    color: inherit;
  }

  :global([data-theme="dark"]) .imgcmp__btn--danger {
    border-color: rgba(231, 76, 60, 0.4);
    color: #ff6b6b;
  }

  :global([data-theme="dark"]) .imgcmp__btn--danger:hover:not(:disabled) {
    background: rgba(231, 76, 60, 0.1);
    color: #ff6b6b;
  }

  :global([data-theme="dark"]) .imgcmp__stat-value--good {
    color: #2ecc71;
  }

  :global([data-theme="dark"]) .imgcmp__stat-value--warn {
    color: #f39c12;
  }

  :global([data-theme="dark"]) .imgcmp__stat-value--bad {
    color: #ff6b6b;
  }

  :global([data-theme="dark"]) .imgcmp__slider-divider {
    background: #5b8cff;
  }

  :global([data-theme="dark"]) .imgcmp__slider-handle {
    background: #5b8cff;
  }

  /* 差异区域列表暗色模式 */
  :global([data-theme="dark"]) .imgcmp__region-btn {
    background: var(--color-bg);
  }

  :global([data-theme="dark"]) .imgcmp__region-item--active .imgcmp__region-btn {
    background: rgba(231, 76, 60, 0.12);
    border-color: #ff6b6b;
  }

  :global([data-theme="dark"]) .imgcmp__region-item--active .imgcmp__region-index {
    background: #ff6b6b;
  }

  /* SVG 区域矩形在暗色模式下提高对比度 */
  :global([data-theme="dark"]) .imgcmp__region-rect {
    fill: rgba(91, 140, 255, 0.15);
    stroke: rgba(91, 140, 255, 1);
  }

  :global([data-theme="dark"]) .imgcmp__region-group:hover .imgcmp__region-rect {
    fill: rgba(91, 140, 255, 0.3);
  }

  :global([data-theme="dark"]) .imgcmp__region-group--active .imgcmp__region-rect {
    fill: rgba(255, 107, 107, 0.3);
    stroke: rgba(255, 107, 107, 1);
  }

  :global([data-theme="dark"]) .imgcmp__region-label-bg {
    fill: rgba(91, 140, 255, 0.95);
  }

  :global([data-theme="dark"]) .imgcmp__region-group--active .imgcmp__region-label-bg {
    fill: rgba(255, 107, 107, 0.95);
  }

  :global([data-theme="dark"]) .imgcmp__region-index {
    background: #5b8cff;
  }

  /* ============================================================
   * 应用模式切换器（单图 / 批量）
   * ============================================================ */
  .imgcmp__appmode {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    padding: 8px;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .imgcmp__appmode-tab {
    flex: 0 0 auto;
    min-height: 44px;
    padding: 8px 18px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm, 4px);
    background: var(--color-bg);
    color: var(--color-text);
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: all var(--transition-fast, 0.15s);
  }

  .imgcmp__appmode-tab:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .imgcmp__appmode-tab--active {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: #fff;
  }

  .imgcmp__appmode-tab--active:hover {
    color: #fff;
  }

  .imgcmp__appmode-tab:focus-visible {
    outline: 2px solid var(--color-primary-ring);
    outline-offset: 2px;
  }

  .imgcmp__appmode-hint {
    flex: 1 1 auto;
    min-width: 200px;
    padding-left: 8px;
    color: var(--color-text-soft);
    font-size: 13px;
  }

  /* ============================================================
   * 批量对比模式
   * ============================================================ */
  .imgcmp__batch {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* 批量拖拽上传区 */
  .imgcmp__batch-drop {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 180px;
    padding: 32px 24px;
    border: 2px dashed var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-soft);
    cursor: pointer;
    transition: border-color var(--transition-fast, 0.15s), background var(--transition-fast, 0.15s);
    text-align: center;
    outline: none;
  }

  .imgcmp__batch-drop:hover,
  .imgcmp__batch-drop:focus-visible,
  .imgcmp__batch-drop--active {
    border-color: var(--color-primary);
    background: var(--color-primary-soft);
    box-shadow: 0 0 0 3px var(--color-primary-ring);
  }

  .imgcmp__batch-drop-icon {
    font-size: 48px;
    line-height: 1;
    margin-bottom: 8px;
  }

  .imgcmp__batch-drop-text {
    font-size: 16px;
    font-weight: 600;
    color: var(--color-text);
  }

  .imgcmp__batch-drop-hint {
    margin-top: 6px;
    font-size: 13px;
    color: var(--color-text-soft);
  }

  /* 文件列表区 */
  .imgcmp__batch-files {
    padding: 14px 16px;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .imgcmp__batch-files-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
  }

  .imgcmp__batch-files-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text);
  }

  .imgcmp__batch-files-pairs {
    color: var(--color-text-soft);
    font-weight: 400;
  }

  .imgcmp__batch-files-unmatched {
    color: #e67e22;
    font-weight: 500;
  }

  /* 配对模式切换器 */
  .imgcmp__pair-mode {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    margin: 12px 0;
    padding: 10px 12px;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .imgcmp__pair-mode-label {
    flex: 0 0 auto;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text);
  }

  .imgcmp__pair-mode-btn {
    flex: 0 0 auto;
    padding: 6px 14px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm, 4px);
    background: var(--color-bg);
    color: var(--color-text-soft);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
    min-height: 32px;
  }

  .imgcmp__pair-mode-btn:hover:not(:disabled) {
    border-color: var(--color-primary, #5b8cff);
    color: var(--color-text);
  }

  .imgcmp__pair-mode-btn--active {
    background: rgba(91, 140, 255, 0.12);
    border-color: #5b8cff;
    color: #5b8cff;
  }

  .imgcmp__pair-mode-btn--active:hover:not(:disabled) {
    background: rgba(91, 140, 255, 0.18);
    color: #4a7ce8;
  }

  .imgcmp__pair-mode-btn:focus-visible {
    outline: 2px solid #5b8cff;
    outline-offset: 2px;
  }

  .imgcmp__pair-mode-btn:disabled {
    cursor: not-allowed;
    opacity: 0.5;
  }

  .imgcmp__pair-mode-hint {
    flex: 1 1 auto;
    min-width: 200px;
    font-size: 12px;
    color: var(--color-text-soft);
    line-height: 1.4;
  }

  /* ============================================================
   *  自定义分隔符 + 分组预览（仅前缀模式显示）
   * ============================================================ */

  /* 配对选项容器：水平布局，左侧自定义分隔符 / 右侧预览按钮 */
  .imgcmp__pair-options {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
    margin: 8px 0 12px;
    padding: 10px 12px;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  /* 自定义分隔符区：左侧开关 + 输入框 + 提示 */
  .imgcmp__pair-separator {
    flex: 1 1 280px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    min-width: 0;
  }

  .imgcmp__pair-separator-toggle {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text);
    cursor: pointer;
    user-select: none;
  }

  .imgcmp__pair-separator-toggle input[type="checkbox"] {
    width: 16px;
    height: 16px;
    cursor: pointer;
    margin: 0;
    accent-color: #5b8cff;
  }

  .imgcmp__pair-separator-input {
    flex: 0 1 160px;
    min-width: 0;
    padding: 6px 10px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm, 4px);
    background: var(--color-bg);
    color: var(--color-text);
    font-size: 13px;
    font-family: ui-monospace, "SFMono-Regular", Consolas, "Liberation Mono", monospace;
    min-height: 32px;
  }

  .imgcmp__pair-separator-input:focus-visible {
    outline: 2px solid #5b8cff;
    outline-offset: 2px;
    border-color: #5b8cff;
  }

  .imgcmp__pair-separator-input:disabled {
    cursor: not-allowed;
    opacity: 0.5;
  }

  .imgcmp__pair-separator-hint {
    flex: 1 1 200px;
    min-width: 0;
    font-size: 12px;
    color: var(--color-text-soft);
    line-height: 1.4;
  }

  /* 预览按钮：紧凑的次按钮 */
  .imgcmp__pair-preview-btn {
    flex: 0 0 auto;
  }

  /* ============================================================
   *  前缀分组预览列表
   * ============================================================ */

  .imgcmp__pair-groups {
    margin: 0 0 12px;
    padding: 12px;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .imgcmp__pair-groups-header {
    margin-bottom: 8px;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text);
  }

  .imgcmp__pair-groups-unmatched {
    color: #e67e22;
    font-weight: 500;
  }

  .imgcmp__pair-groups-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
    max-height: 480px;
    overflow-y: auto;
  }

  /* 单个分组卡片 */
  .imgcmp__pair-group {
    padding: 10px 12px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-left: 4px solid #5b8cff;
    border-radius: var(--radius-sm, 4px);
  }

  /* 单文件组：红色左边框 */
  .imgcmp__pair-group--odd {
    border-left-color: #e74c3c;
  }

  /* 超过 2 个文件组：橙色左边框 */
  .imgcmp__pair-group--over2 {
    border-left-color: #e67e22;
  }

  .imgcmp__pair-group-header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    margin-bottom: 6px;
  }

  .imgcmp__pair-group-prefix {
    font-family: ui-monospace, "SFMono-Regular", Consolas, "Liberation Mono", monospace;
    font-size: 13px;
    font-weight: 700;
    color: var(--color-text);
    word-break: break-all;
  }

  .imgcmp__pair-group-count {
    font-size: 12px;
    color: var(--color-text-soft);
  }

  .imgcmp__pair-group-badge {
    display: inline-flex;
    align-items: center;
    padding: 2px 8px;
    border-radius: 10px;
    font-size: 11px;
    font-weight: 600;
  }

  .imgcmp__pair-group-badge--odd {
    background: rgba(231, 76, 60, 0.12);
    color: #c0392b;
  }

  .imgcmp__pair-group-badge--over2 {
    background: rgba(230, 126, 34, 0.12);
    color: #b8651a;
  }

  .imgcmp__pair-group-files {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  /* 单个配对行：A 文件名 vs B 文件名 */
  .imgcmp__pair-group-pair {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--color-text);
    line-height: 1.4;
  }

  .imgcmp__pair-group-pair--leftover {
    opacity: 0.7;
  }

  .imgcmp__pair-group-role {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 22px;
    padding: 1px 6px;
    border-radius: 3px;
    font-size: 11px;
    font-weight: 700;
    font-family: ui-monospace, "SFMono-Regular", Consolas, "Liberation Mono", monospace;
  }

  .imgcmp__pair-group-role--a {
    background: rgba(91, 140, 255, 0.18);
    color: #2c5fd6;
  }

  .imgcmp__pair-group-role--b {
    background: rgba(46, 204, 113, 0.18);
    color: #1d8a4f;
  }

  .imgcmp__pair-group-role--none {
    background: rgba(231, 76, 60, 0.12);
    color: #c0392b;
    min-width: 56px;
  }

  .imgcmp__pair-group-name {
    flex: 1 1 auto;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-family: ui-monospace, "SFMono-Regular", Consolas, "Liberation Mono", monospace;
  }

  .imgcmp__pair-group-vs {
    flex: 0 0 auto;
    color: var(--color-text-soft);
    font-size: 11px;
    font-style: italic;
  }

  /* 未配对文件样式（前缀模式下未匹配到同前缀的文件） */
  .imgcmp__batch-file-item--unmatched {
    opacity: 0.65;
    background: rgba(231, 76, 60, 0.04);
    border-style: dashed;
  }

  .imgcmp__batch-file-role--none {
    background: rgba(231, 76, 60, 0.12);
    color: #c0392b;
  }

  .imgcmp__batch-files-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
    max-height: 360px;
    overflow-y: auto;
  }

  .imgcmp__batch-file-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 10px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm, 4px);
    font-size: 13px;
  }

  .imgcmp__batch-file-index {
    flex: 0 0 auto;
    min-width: 28px;
    height: 24px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-soft);
    border-radius: var(--radius-sm, 4px);
    color: var(--color-text-soft);
    font-size: 12px;
    font-weight: 600;
  }

  .imgcmp__batch-file-name {
    flex: 1 1 auto;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--color-text);
  }

  .imgcmp__batch-file-meta {
    flex: 0 0 auto;
    color: var(--color-text-soft);
    font-size: 12px;
  }

  .imgcmp__batch-file-role {
    flex: 0 0 auto;
    padding: 2px 8px;
    border-radius: var(--radius-sm, 4px);
    font-size: 11px;
    font-weight: 600;
  }

  .imgcmp__batch-file-role--a {
    background: rgba(91, 140, 255, 0.15);
    color: #5b8cff;
  }

  .imgcmp__batch-file-role--b {
    background: rgba(231, 76, 60, 0.15);
    color: #c0392b;
  }

  .imgcmp__batch-file-remove {
    flex: 0 0 auto;
    width: 28px;
    height: 28px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm, 4px);
    background: var(--color-bg);
    color: var(--color-text-soft);
    font-size: 16px;
    line-height: 1;
    cursor: pointer;
    transition: all var(--transition-fast, 0.15s);
  }

  .imgcmp__batch-file-remove:hover:not(:disabled) {
    border-color: #e74c3c;
    color: #e74c3c;
  }

  .imgcmp__batch-file-remove:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* 进度条 */
  .imgcmp__batch-progress {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    background: var(--color-bg-soft);
    border-radius: var(--radius-md);
  }

  .imgcmp__batch-progress-bar {
    flex: 1 1 auto;
    height: 8px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    overflow: hidden;
  }

  .imgcmp__batch-progress-fill {
    height: 100%;
    background: var(--color-primary);
    transition: width 0.2s ease-out;
  }

  .imgcmp__batch-progress-text {
    flex: 0 0 auto;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text);
  }

  /* 配对结果列表 */
  .imgcmp__batch-list {
    margin-top: 8px;
  }

  .imgcmp__batch-items {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .imgcmp__batch-item {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .imgcmp__batch-item--expanded {
    border-color: var(--color-primary);
  }

  .imgcmp__batch-item-header {
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    min-height: 44px;
    padding: 10px 14px;
    background: transparent;
    border: none;
    text-align: left;
    cursor: pointer;
    transition: background var(--transition-fast, 0.15s);
  }

  .imgcmp__batch-item-header:hover:not(:disabled) {
    background: var(--color-bg-soft);
  }

  .imgcmp__batch-item-header:disabled {
    cursor: not-allowed;
    opacity: 0.7;
  }

  .imgcmp__batch-item-index {
    flex: 0 0 auto;
    min-width: 36px;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text-soft);
  }

  .imgcmp__batch-item-pair {
    flex: 1 1 auto;
    display: flex;
    align-items: center;
    gap: 6px;
    min-width: 0;
    font-size: 13px;
  }

  .imgcmp__batch-item-name {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--color-text);
  }

  .imgcmp__batch-item-vs {
    flex: 0 0 auto;
    color: var(--color-text-soft);
    font-size: 12px;
    font-style: italic;
  }

  .imgcmp__batch-item-percent {
    flex: 0 0 auto;
    font-size: 14px;
    font-weight: 600;
  }

  .imgcmp__batch-item-level {
    font-size: 12px;
    font-weight: 400;
    color: var(--color-text-soft);
  }

  .imgcmp__batch-item-error {
    flex: 0 0 auto;
    font-size: 12px;
    color: #c0392b;
  }

  /* 展开的详情区 */
  .imgcmp__batch-item-detail {
    padding: 14px;
    border-top: 1px solid var(--color-border);
    background: var(--color-bg-soft);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .imgcmp__batch-item-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 16px;
    font-size: 12px;
    color: var(--color-text-soft);
  }

  /* 响应式：768px 以下 */
  @media (max-width: 768px) {
    .imgcmp__appmode-hint {
      flex: 1 1 100%;
      padding-left: 0;
    }

    .imgcmp__batch-file-item {
      flex-wrap: wrap;
    }

    .imgcmp__batch-file-name {
      flex: 1 1 calc(100% - 80px);
    }

    .imgcmp__batch-item-pair {
      flex: 1 1 100%;
      flex-wrap: wrap;
    }

    .imgcmp__batch-item-percent {
      flex: 0 0 auto;
    }

    /* 自定义分隔符区在 768px 以下换行展示 */
    .imgcmp__pair-separator-hint {
      flex: 1 1 100%;
    }

    .imgcmp__pair-separator-input {
      flex: 1 1 160px;
    }

    /* 分组预览按钮在窄屏占满整行 */
    .imgcmp__pair-preview-btn {
      flex: 1 1 100%;
    }

    /* 分组卡片配对行换行更紧凑 */
    .imgcmp__pair-group-pair {
      flex-wrap: wrap;
    }
  }

  /* 响应式：480px 以下 */
  @media (max-width: 480px) {
    .imgcmp__batch-drop {
      min-height: 140px;
      padding: 20px 16px;
    }

    .imgcmp__batch-drop-icon {
      font-size: 36px;
    }

    .imgcmp__batch-file-meta {
      flex: 0 0 100%;
      font-size: 11px;
    }

    .imgcmp__batch-item-index {
      min-width: 28px;
      font-size: 12px;
    }

    .imgcmp__batch-item-stats {
      flex-direction: column;
      gap: 4px;
    }

    /* 自定义分隔符输入框与字号在窄屏缩小 */
    .imgcmp__pair-separator-input {
      font-size: 12px;
      padding: 5px 8px;
    }

    .imgcmp__pair-separator-toggle {
      font-size: 12px;
    }

    /* 分组卡片字号缩小 */
    .imgcmp__pair-group-prefix {
      font-size: 12px;
    }

    .imgcmp__pair-group-pair {
      font-size: 11px;
    }

    .imgcmp__pair-groups-list {
      max-height: 360px;
    }
  }

  /* 暗色模式适配 */
  :global([data-theme="dark"]) .imgcmp__appmode {
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(255, 255, 255, 0.1);
  }

  :global([data-theme="dark"]) .imgcmp__appmode-tab {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.1);
    color: var(--color-text);
  }

  :global([data-theme="dark"]) .imgcmp__batch-drop {
    background: rgba(255, 255, 255, 0.03);
  }

  :global([data-theme="dark"]) .imgcmp__batch-files {
    background: rgba(255, 255, 255, 0.03);
  }

  :global([data-theme="dark"]) .imgcmp__batch-file-item {
    background: rgba(0, 0, 0, 0.2);
  }

  :global([data-theme="dark"]) .imgcmp__batch-file-index {
    background: rgba(255, 255, 255, 0.08);
  }

  :global([data-theme="dark"]) .imgcmp__batch-file-role--a {
    background: rgba(91, 140, 255, 0.25);
    color: #8fb3ff;
  }

  :global([data-theme="dark"]) .imgcmp__batch-file-role--b {
    background: rgba(231, 76, 60, 0.25);
    color: #ff7b6b;
  }

  :global([data-theme="dark"]) .imgcmp__batch-item {
    background: rgba(0, 0, 0, 0.2);
  }

  :global([data-theme="dark"]) .imgcmp__batch-item-detail {
    background: rgba(0, 0, 0, 0.3);
  }

  :global([data-theme="dark"]) .imgcmp__batch-item-error {
    color: #ff7b6b;
  }

  /* 暗色模式：自定义分隔符 + 分组预览 */
  :global([data-theme="dark"]) .imgcmp__pair-options {
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(255, 255, 255, 0.1);
  }

  :global([data-theme="dark"]) .imgcmp__pair-separator-input {
    background: rgba(0, 0, 0, 0.3);
    border-color: rgba(255, 255, 255, 0.12);
    color: var(--color-text);
  }

  :global([data-theme="dark"]) .imgcmp__pair-groups {
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(255, 255, 255, 0.1);
  }

  :global([data-theme="dark"]) .imgcmp__pair-group {
    background: rgba(0, 0, 0, 0.2);
    border-color: rgba(255, 255, 255, 0.1);
  }

  :global([data-theme="dark"]) .imgcmp__pair-group-role--a {
    background: rgba(91, 140, 255, 0.25);
    color: #8fb3ff;
  }

  :global([data-theme="dark"]) .imgcmp__pair-group-role--b {
    background: rgba(46, 204, 113, 0.22);
    color: #6ddc91;
  }

  :global([data-theme="dark"]) .imgcmp__pair-group-role--none {
    background: rgba(231, 76, 60, 0.25);
    color: #ff7b6b;
  }

  :global([data-theme="dark"]) .imgcmp__pair-group-badge--odd {
    background: rgba(231, 76, 60, 0.25);
    color: #ff7b6b;
  }

  :global([data-theme="dark"]) .imgcmp__pair-group-badge--over2 {
    background: rgba(230, 126, 34, 0.25);
    color: #ffa860;
  }

  /* ============================================================
   *  区域放大 Modal
   * ============================================================ */

  /* 遮罩层：固定定位 + 居中布局 + 半透明背景 */
  .imgcmp__zoom-overlay {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
  }

  /* modal 容器：限宽 + 限高 + 内部滚动 */
  .imgcmp__zoom-dialog {
    display: flex;
    flex-direction: column;
    width: 100%;
    max-width: 1200px;
    max-height: calc(100vh - 32px);
    background: var(--color-bg, #fff);
    border-radius: var(--radius-md, 8px);
    box-shadow: 0 12px 48px rgba(0, 0, 0, 0.3);
    overflow: hidden;
  }

  /* 顶部：标题 + 元信息 + 放大倍率切换器 + 关闭按钮 */
  .imgcmp__zoom-header {
    display: flex;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 12px 16px;
    padding: 16px 20px;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg-soft, rgba(0, 0, 0, 0.02));
  }

  .imgcmp__zoom-title-wrap {
    flex: 1 1 240px;
    min-width: 0;
  }

  /* 放大倍率切换器：role=radiogroup */
  .imgcmp__zoom-scale {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 3px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm, 4px);
    background: var(--color-bg);
    flex-shrink: 0;
  }

  .imgcmp__zoom-scale-btn {
    padding: 4px 12px;
    border: none;
    border-radius: 3px;
    background: transparent;
    color: var(--color-text-soft);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
    min-height: 28px;
    line-height: 1;
  }

  .imgcmp__zoom-scale-btn:hover:not(:disabled):not(.imgcmp__zoom-scale-btn--active) {
    color: var(--color-text);
    background: var(--color-bg-soft);
  }

  .imgcmp__zoom-scale-btn--active {
    background: var(--color-primary);
    color: #fff;
  }

  .imgcmp__zoom-scale-btn:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring, 0 0 0 3px var(--color-primary-ring));
  }

  .imgcmp__zoom-scale-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* 三联合成图下载按钮 */
  .imgcmp__zoom-download {
    padding: 8px 14px;
    border: 1px solid var(--color-primary);
    border-radius: var(--radius-sm, 4px);
    background: var(--color-primary);
    color: #fff;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: opacity 0.15s, background 0.15s;
    min-height: 44px;
    white-space: nowrap;
  }

  .imgcmp__zoom-download:hover:not(:disabled) {
    opacity: 0.9;
    background: var(--color-primary-strong, var(--color-primary));
  }

  .imgcmp__zoom-download:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring, 0 0 0 3px var(--color-primary-ring));
  }

  .imgcmp__zoom-download:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  /* 合成图下载失败提示 */
  .imgcmp__zoom-compose-error {
    padding: 10px 20px;
    background: rgba(231, 76, 60, 0.08);
    color: #c0392b;
    font-size: 12px;
    border-top: 1px solid rgba(231, 76, 60, 0.3);
  }

  .imgcmp__zoom-title {
    margin: 0 0 4px;
    font-size: 16px;
    font-weight: 600;
    color: var(--color-text);
  }

  .imgcmp__zoom-meta {
    margin: 0;
    font-size: 12px;
    color: var(--color-text-soft);
    font-family: ui-monospace, "SFMono-Regular", Menlo, Monaco, Consolas, monospace;
    word-break: break-all;
  }

  .imgcmp__zoom-divider {
    margin: 0 6px;
    opacity: 0.5;
  }

  .imgcmp__zoom-close {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm, 4px);
    background: var(--color-bg);
    color: var(--color-text);
    font-size: 22px;
    line-height: 1;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
  }

  .imgcmp__zoom-close:hover {
    border-color: #c0392b;
    color: #c0392b;
    background: rgba(231, 76, 60, 0.06);
  }

  .imgcmp__zoom-close:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring, 0 0 0 3px var(--color-primary-ring));
  }

  /* 中部：三联放大图 */
  .imgcmp__zoom-body {
    flex: 1;
    overflow: auto;
    padding: 20px;
