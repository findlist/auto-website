---
import BaseLayout, { type SiteMeta } from '../layouts/BaseLayout.astro';
import ImageCompareTool from '../components/ImageCompareTool.tsx';

const meta: SiteMeta = {
  title: '图片对比工具 - 在线图片差异比较（左右并排 / 滑块叠加 / 像素差异高亮）',
  description:
    '在线图片对比工具：支持左右并排、滑块叠加、像素级差异高亮三种对比模式，逐像素分析两张图的差异区域并以红色高亮标记，输出差异像素数、差异比例、最大差异强度等统计数据。支持阈值调节（0-100，可切换严格/默认/宽松三档预设）与差异图导出 PNG。基于 Canvas API 与 ImageData 全本地处理，零上传、零追踪、可离线使用，适用于设计稿版本对比、A/B 素材对比、回归测试截图对比、压缩前后质量对比等场景。',
  jsonLd: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: '图片对比工具',
    description: '在线图片对比工具，支持左右并排、滑块叠加、像素差异高亮三种模式，阈值调节与差异统计，全本地 Canvas API 处理。',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Any (Web Browser)',
    inLanguage: 'zh-CN',
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'CNY',
    },
  },
};
---
<BaseLayout meta={meta}>
  <section class="container">
    <div class="page-hero page-hero--tool">
      <h1>图片对比工具</h1>
      <p>
        纯本地处理的<strong>在线图片对比工具</strong>，提供三种对比模式：
        <strong>左右并排</strong>（等比缩放后并排展示）、
        <strong>滑块叠加</strong>（拖动垂直分隔线对比同一区域）、
        <strong>像素级差异高亮</strong>（相同区域灰度化、差异区域红色标记）。
        差异模式逐像素分析，输出<strong>差异像素数、差异比例、最大差异强度、平均差异强度</strong>等统计，
        支持<strong>阈值调节</strong>（0-100，可切换严格/默认/宽松三档预设）。
        基于 Canvas API 的 ImageData 在浏览器本地完成对比，<strong>零上传、零追踪、可离线使用</strong>，
        适用于设计稿版本对比、A/B 素材对比、回归测试截图对比、压缩前后质量对比等场景。
      </p>
    </div>

    <!-- client:load 让 React 岛屿在页面加载时立即水合，保证拖拽与粘贴交互即时可用 -->
    <ImageCompareTool client:load />

    <!-- 常见问题：补充 SEO 内容 + 解决核心用户疑问 -->
    <section class="json-faq" aria-labelledby="faq-title">
      <h2 id="faq-title">常见问题</h2>
      <details>
        <summary>三种对比模式分别适合什么场景？</summary>
        <p>
          三种模式各有侧重，可按需切换：<br />
          - <strong>左右并排</strong>：适合<strong>快速整体浏览对比</strong>，两张图等比缩放后并排拼接为一张图，
          一眼即可看到整体差异，可下载为合成图用于汇报与文档<br />
          - <strong>滑块叠加</strong>：适合<strong>同区域细节对比</strong>，两张图叠加后通过可拖动的垂直分隔线
          在同一位置切换查看，便于观察细微改动（如按钮颜色、文字微调、像素级对齐）<br />
          - <strong>差异高亮</strong>：适合<strong>精确像素差异分析</strong>，逐像素对比后将差异区域
          以红色高亮标记，并输出差异像素数、差异比例等统计，适用于回归测试与质量验证
        </p>
      </details>
      <details>
        <summary>像素差异是怎么计算的？</summary>
        <p>
          本工具使用<strong>感知加权欧几里得距离</strong>（基于 ITU-R BT.601 颜色权重）计算两像素的差异强度：
          对每个像素的 R/G/B 三个通道按 <code>0.299 * ΔR² + 0.587 * ΔG² + 0.114 * ΔB²</code> 加权求和后开方，
          权重反映人眼对绿色最敏感、对蓝色最不敏感的特性，结果归一化到 0-255 范围。
          若该差异值大于<strong>阈值</strong>则判定为差异像素，标记为红色高亮；否则视为相同像素，灰度化显示。
          全部计算在浏览器本地的 Canvas API 与 ImageData 中完成，无任何网络请求。
        </p>
      </details>
      <details>
        <summary>差异阈值（0-100）应该怎么选？</summary>
        <p>
          阈值决定判定像素是否为"差异"的敏感度，本工具提供三档预设：<br />
          - <strong>严格（5）</strong>：极低阈值，捕捉细微差异。适用于<strong>回归测试、像素级验证</strong>等
          需要检测任何改动的场景，但可能将 JPEG 重编码噪声误判为差异<br />
          - <strong>默认（20）</strong>：平衡可见性与噪声的推荐值。适用于<strong>一般对比、设计稿版本对比</strong>等
          大多数场景，能过滤编码噪声同时保留人眼可见差异<br />
          - <strong>宽松（50）</strong>：高阈值，仅保留显著差异。适用于<strong>压缩损失对比、明显改动检测</strong>等
          只关心重大差异的场景，可彻底过滤细微噪声<br />
          也可手动滑动滑块自定义阈值，实时查看差异图变化。
        </p>
      </details>
      <details>
        <summary>两张图尺寸不同能对比吗？</summary>
        <p>
          可以。本工具会自动取两张图中<strong>较小的宽度和高度</strong>作为对比区域，仅在该共同区域内进行像素对比，
          超出区域的部分不参与计算。例如图片 A 是 1920×1080、图片 B 是 1280×720，
          则在 1280×720 区域内对比，A 的右下角超出区域不参与计算。
          页面会显示尺寸差异提示（"两张图尺寸不同，将以共同区域 WxH 进行对比"）告知用户实际对比范围。
          如需<strong>完全相同尺寸</strong>对比，建议先用<a href="/image-resize">图片缩放工具</a>
          或<a href="/image-crop">图片裁剪工具</a>统一尺寸后再对比。
        </p>
      </details>
      <details>
        <summary>滑块叠加模式如何操作？支持触摸屏吗？</summary>
        <p>
          滑块叠加模式提供两种操作方式：<br />
          - <strong>鼠标</strong>：在对比区域内<strong>按住左键拖动</strong>，分隔线会跟随鼠标位置移动；
          也可点击区域任意位置直接跳转到该位置<br />
          - <strong>触摸屏</strong>：支持<strong>单指拖动</strong>分隔线，适配移动端与平板设备<br />
          - <strong>键盘</strong>：聚焦后使用 <code>←</code> / <code>→</code> 方向键
          每次移动 2%，满足无障碍访问需求<br />
          分隔线左侧显示图片 A、右侧显示图片 B，分隔线上有 ⇄ 拖动把手提示。
          左右两侧的 A / B 字母标签帮助快速识别当前查看的是哪张图。
        </p>
      </details>
      <details>
        <summary>差异统计中的"最大差异"和"平均差异强度"是什么？</summary>
        <p>
          两个指标帮助评估差异的剧烈程度：<br />
          - <strong>最大差异（0-255）</strong>：所有像素中差异最大的那个像素的差异值。
          值越大表示存在非常明显的差异（如完全相反的颜色）；值为 0 表示两图完全相同<br />
          - <strong>平均差异强度（0-255）</strong>：仅统计被判定为差异的像素的平均差异值，
          反映差异的<strong>平均剧烈程度</strong>。值越高表示差异区域整体改动越大<br />
          <strong>使用场景</strong>：差异比例为 5% 时，若平均差异强度高（如 100+），说明是少量但明显的改动
          （如 Logo 颜色变化）；若平均差异强度低（如 20-30），说明是少量细微改动（如压缩噪声）。
        </p>
      </details>
      <details>
        <summary>支持哪些图片格式？支持 GIF 动图吗？</summary>
        <p>
          支持 <strong>PNG / JPEG / WebP / GIF / BMP / AVIF</strong> 六种常见格式输入。
          对于 <strong>GIF 动图</strong>，Canvas API 仅取<strong>首帧</strong>进行对比（这是浏览器原生限制：
          <code>drawImage</code> 只绘制第一帧），因此对比结果是首帧的差异，不适用于多帧动画对比。
          如需对比不同格式的图片（如 PNG vs JPEG），可直接上传，工具会自动统一到共同尺寸后对比。
          输入文件大小上限为 <strong>30MB</strong>，避免浏览器内存压力。
        </p>
      </details>
      <details>
        <summary>图片会上传到服务器吗？</summary>
        <p>
          不会。本工具完全在浏览器内运行，所有对比处理由 Canvas API 的 ImageData 在本地执行，
          不会发送任何图片数据到服务器。使用 <code>URL.createObjectURL()</code> 创建本地预览 URL，
          对比结果在内存中生成可直接下载。全程零网络请求，可离线使用。
          可在浏览器开发者工具 Network 面板确认无任何外部请求。
        </p>
      </details>
      <details>
        <summary>差异图导出什么格式？</summary>
        <p>
          差异图导出为 <strong>PNG 格式</strong>（<code>image/png</code>），原因：<br />
          - <strong>无损压缩</strong>：保留精确像素信息，避免二次压缩导致差异区域失真<br />
          - <strong>支持透明</strong>：差异像素的半透明叠加效果可完整保留<br />
          - <strong>广泛兼容</strong>：所有平台与浏览器均支持查看与嵌入<br />
          文件名格式为 <code>原文件名-diff.png</code>（如 <code>design-v1-diff.png</code>）。
          左右并排模式的合成图同样导出为 PNG，文件名格式为 <code>原文件名-compare.png</code>。
        </p>
      </details>
      <details>
        <summary>与图片压缩工具有什么关系？</summary>
        <p>
          两者常配合使用：<br />
          - <strong>图片压缩工具</strong>（<a href="/image-compress">/image-compress</a>）：
          专注于<strong>体积压缩</strong>，输出压缩后的图片<br />
          - <strong>本对比工具</strong>：可用于<strong>评估压缩前后的视觉差异</strong>，
          将原图与压缩图对比，差异高亮模式下可量化压缩带来的视觉损失<br />
          <strong>典型工作流</strong>：上传原图到压缩工具 → 调整质量参数得到压缩图 →
          上传原图与压缩图到本工具 → 切换"差异高亮"模式查看压缩损失区域 →
          根据差异比例与平均差异强度选择合适的压缩质量。
        </p>
      </details>
    </section>

    <!-- 相关工具：图像处理矩阵内链，提升站内导航与 SEO 内链结构 -->
    <section class="related-tools" aria-labelledby="related-title">
      <h2 id="related-title">相关工具</h2>
      <ul class="related-tools__list">
        <li><a href="/exif">EXIF 查看</a> —— 图片元数据解析（相机参数、GPS）</li>
        <li><a href="/exif-editor">EXIF 元数据编辑器</a> —— 删除 GPS / 个人信息 / 修改拍摄时间</li>
        <li><a href="/image-compress">图片压缩</a> —— PNG/JPEG/WebP 压缩与质量调节</li>
        <li><a href="/image-convert">图片格式转换</a> —— PNG/JPEG/WebP/AVIF 批量互转</li>
        <li><a href="/image-resize">图片缩放</a> —— 5 种模式 + 8 种预设 + 等比锁定</li>
        <li><a href="/image-crop">图片裁剪</a> —— 可视化裁剪框 + 9 种比例 + 撤销重做</li>
        <li><a href="/image-watermark">图片水印</a> —— 文字/图片水印批量添加</li>
        <li><a href="/base64-image">Base64 图片互转</a> —— 图片与 data URL 互转</li>
        <li><a href="/svg-optimizer">SVG 优化器</a> —— 矢量图压缩与编辑器残留清理</li>
      </ul>
    </section>

    <!-- 相关博客：工具页反向内链，引导用户深度阅读（脚本批量生成，请勿手动修改） -->
    <section class="related-blogs" aria-labelledby="related-blogs-title">
      <h2 id="related-blogs-title">相关博客</h2>
      <ul class="related-blogs__list">
        <li>
          <a href="/blog/image-comparison-guide">图片对比工具深度指南：像素差异算法、阈值选择与最佳实践</a><span class="related-blogs__desc">系统讲解图片对比工具的实现原理：感知加权欧几里得距离的像素差异算法、阈值选择策略、三种对比模式（左右并排 / 滑块叠加 / 差异高亮）的适用场景。帮助开发者理解浏览器端图片对…</span>
        </li>
        <li>
          <a href="/blog/regression-test-screenshot-diff">回归测试截图差异分析实践：从手工比对到像素级量化对比</a><span class="related-blogs__desc">系统讲解回归测试中截图差异分析的完整实践：为什么需要像素级对比、手工比对与自动化对比的差距、感知加权欧几里得距离算法在 UI 回归测试中的应用、阈值选择策略（严格 5 / 默…</span>
        </li>
      </ul>
    </section>
  </section>
</BaseLayout>

<style is:global>
  /* 图片对比工具专属样式：imgcmp 命名空间 */
  .imgcmp {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* 双图上传区 */
  .imgcmp__uploads {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  /* 单图上传 slot */
  .imgcmp__slot {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 220px;
    padding: 24px;
    border: 2px dashed var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-soft);
    cursor: pointer;
    transition: border-color var(--transition-fast, 0.15s), background var(--transition-fast, 0.15s);
    text-align: center;
    outline: none;
  }

  .imgcmp__slot:hover,
  .imgcmp__slot:focus-visible,
  .imgcmp__slot--active {
    border-color: var(--color-primary);
    background: var(--color-primary-soft);
    box-shadow: 0 0 0 3px var(--color-primary-ring);
  }

  .imgcmp__slot--filled {
    cursor: default;
    padding: 12px;
    border-style: solid;
    border-color: var(--color-border);
    background: var(--color-bg);
  }

  .imgcmp__slot--filled:hover {
    border-color: var(--color-border);
    background: var(--color-bg);
    box-shadow: none;
  }

  /* 空状态 */
  .imgcmp__slot-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .imgcmp__slot-icon {
    font-size: 40px;
    line-height: 1;
  }

  .imgcmp__slot-text {
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text);
  }

  .imgcmp__slot-hint {
    font-size: 12px;
    color: var(--color-text-soft);
  }

  /* 已填充预览 */
  .imgcmp__slot-preview {
    display: flex;
    flex-direction: column;
    gap: 10px;
    width: 100%;
  }

  .imgcmp__slot-img {
    width: 100%;
    max-height: 220px;
    object-fit: contain;
    border-radius: var(--radius-sm, 4px);
    background: var(--color-bg-soft);
  }

  .imgcmp__slot-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .imgcmp__slot-name {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .imgcmp__slot-meta {
    font-size: 12px;
    color: var(--color-text-soft);
  }

  .imgcmp__slot-actions {
    display: flex;
    gap: 6px;
    margin-top: 4px;
  }

  /* 提示信息 */
  .imgcmp__error {
    padding: 12px 16px;
    border-radius: var(--radius-md);
    background: rgba(231, 76, 60, 0.08);
    border-left: 3px solid #e74c3c;
    color: #c0392b;
    font-size: 14px;
  }

  .imgcmp__notice {
    padding: 10px 14px;
    border-radius: var(--radius-md);
    background: rgba(241, 196, 15, 0.08);
    border-left: 3px solid #f1c40f;
    color: #8b6914;
    font-size: 13px;
  }

  /* 控制面板 */
  .imgcmp__panel {
    display: flex;
    flex-direction: column;
    gap: 18px;
    padding: 18px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-soft);
  }

  .imgcmp__field-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .imgcmp__field-label {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text);
  }

  .imgcmp__field-value {
    color: var(--color-primary);
    font-weight: 700;
    margin-left: 4px;
  }

  /* 模式切换 Tab */
  .imgcmp__mode-tabs {
    display: flex;
    gap: 4px;
    padding: 4px;
    background: var(--color-bg);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
  }

  .imgcmp__mode-tab {
    flex: 1;
    min-height: 44px;
    padding: 8px 12px;
    border: none;
    background: transparent;
    color: var(--color-text-soft);
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    border-radius: var(--radius-sm, 4px);
    transition: all var(--transition-fast, 0.15s);
  }

  .imgcmp__mode-tab:hover {
    color: var(--color-text);
  }

  .imgcmp__mode-tab--active {
    background: var(--color-primary);
    color: #fff;
    font-weight: 600;
    box-shadow: 0 1px 3px rgba(43, 108, 255, 0.3);
  }

  .imgcmp__mode-desc {
    font-size: 12px;
    color: var(--color-text-soft);
    margin-top: 2px;
  }

  /* 范围滑块 */
  .imgcmp__range {
    width: 100%;
    height: 32px;
    cursor: pointer;
  }

  /* 阈值预设按钮 */
  .imgcmp__preset-row {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .imgcmp__preset-btn {
    padding: 6px 12px;
    min-height: 36px;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text-soft);
    font-size: 13px;
    border-radius: var(--radius-sm, 4px);
    cursor: pointer;
    transition: all var(--transition-fast, 0.15s);
  }

  .imgcmp__preset-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .imgcmp__preset-btn--active {
    background: var(--color-primary);
    color: #fff;
    border-color: var(--color-primary);
  }

  .imgcmp__hint {
    font-size: 12px;
    color: var(--color-text-muted);
    margin-top: 4px;
  }

  /* 操作按钮 */
  .imgcmp__actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .imgcmp__btn {
    padding: 10px 18px;
    min-height: 44px;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
    font-size: 14px;
    font-weight: 500;
    border-radius: var(--radius-md);
    cursor: pointer;
