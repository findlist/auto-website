<style>
  /* 工具页专属样式：hh 命名空间（http-headers） */

  /* 容器与标签页 */
  .hh__container {
    margin: 24px 0;
  }

  .hh__tabs {
    display: flex;
    gap: 4px;
    border-bottom: 2px solid var(--color-border);
    margin-bottom: 16px;
  }

  .hh__tab {
    padding: 8px 18px;
    border: none;
    background: transparent;
    color: var(--color-text-muted, #6b7280);
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    transition: color 0.15s, border-color 0.15s;
  }

  .hh__tab:hover {
    color: var(--color-text);
  }

  .hh__tab.is-active {
    color: var(--color-accent, #2563eb);
    border-bottom-color: var(--color-accent, #2563eb);
    font-weight: 600;
  }

  /* 通用控件 */
  .hh__controls {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .hh__input,
  .hh__select,
  .hh__textarea {
    padding: 8px 12px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm, 6px);
    background: var(--color-bg);
    color: var(--color-text);
    font-size: 13px;
    font-family: inherit;
  }

  .hh__textarea {
    font-family: ui-monospace, "SF Mono", Consolas, monospace;
    resize: vertical;
    line-height: 1.6;
    width: 100%;
  }

  .hh__search {
    flex: 1;
    min-width: 240px;
  }

  .hh__input:focus,
  .hh__select:focus,
  .hh__textarea:focus {
    outline: 2px solid var(--color-accent, #2563eb);
    outline-offset: 1px;
    border-color: var(--color-accent, #2563eb);
  }

  /* 分类筛选 chips */
  .hh__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .hh__chip {
    padding: 4px 12px;
    border: 1px solid var(--color-border);
    border-radius: 16px;
    background: var(--color-bg);
    color: var(--color-text-muted, #6b7280);
    font-size: 12px;
    cursor: pointer;
    transition: all 0.15s;
  }

  .hh__chip:hover {
    color: var(--color-text);
    border-color: var(--color-text-muted, #6b7280);
  }

  .hh__chip.is-active {
    background: var(--color-accent, #2563eb);
    color: #fff;
    border-color: var(--color-accent, #2563eb);
  }

  /* 按钮 */
  .hh__btn {
    padding: 6px 14px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm, 6px);
    background: var(--color-bg);
    color: var(--color-text);
    font-size: 13px;
    cursor: pointer;
    transition: all 0.15s;
  }

  .hh__btn--ghost {
    background: transparent;
  }

  .hh__btn--ghost:hover {
    background: var(--color-bg-soft, rgba(0, 0, 0, 0.03));
  }

  .hh__btn--primary {
    background: var(--color-accent, #2563eb);
    color: #fff;
    border-color: var(--color-accent, #2563eb);
  }

  .hh__btn--primary:hover {
    opacity: 0.9;
  }

  /* 空状态 */
  .hh__empty {
    padding: 32px 16px;
    text-align: center;
    color: var(--color-text-muted, #6b7280);
    font-size: 14px;
  }

  .hh__empty p {
    margin: 0 0 8px;
  }

