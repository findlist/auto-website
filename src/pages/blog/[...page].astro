---
import type { GetStaticPaths } from 'astro';
import BaseLayout, { type SiteMeta } from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { tagToSlug } from '../../utils/tags';
import { getSiteUrl, normalizeUrlTrailingSlash } from '../../utils/site';

// 每页显示的文章数量：12 篇平衡浏览体验与页面数量

// 静态分页：getStaticPaths + paginate 生成 /blog（第 1 页）、/blog/2、/blog/3 …
export const getStaticPaths = (async ({ paginate }) => {
  const PAGE_SIZE = 12;
  const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  );
  return paginate(posts, { pageSize: PAGE_SIZE });
}) satisfies GetStaticPaths;

// 日期格式化：中文长格式
const formatDate = (date: Date) =>
  date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });

const SITE_URL = getSiteUrl(Astro.site);
const { page } = Astro.props;

// 当前页文章列表
const posts = page.data;

// canonical 绝对 URL：第 1 页为 /blog/，后续页为 /blog/N/
// BaseLayout 会统一规范化尾部斜杠，此处保持原始 page.url.current 即可
const canonical = new URL(page.url.current, SITE_URL).toString();
// 分页 SEO 信号：转为绝对 URL 供 <link rel="prev/next"> 使用
const prevUrl = page.url.prev ? new URL(page.url.prev, SITE_URL).toString() : undefined;
const nextUrl = page.url.next ? new URL(page.url.next, SITE_URL).toString() : undefined;

// 分页标题：第 1 页保持原标题，后续页追加页码后缀
const title =
  page.currentPage > 1
    ? `技术博客（第 ${page.currentPage} 页）- 开发者工具实践指南`
    : '技术博客 - 开发者工具实践指南';

// 博客发布者实体：与首页 Organization 保持一致，形成站点级实体呼应
const orgEntity = {
  '@type': 'Organization',
  name: '工具盒子',
  url: SITE_URL,
  description: '面向中文开发者的现代化在线工具集，全本地处理，零广告零追踪。',
};

// Blog JSON-LD：blogPost 列出全部文章（Blog 实体代表博客整体，非单页）
const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const meta: SiteMeta = {
  title,
  description:
    '深入探讨 JSON、UUID、Base64、Hash 等开发者工具背后的技术原理与最佳实践。涵盖 JavaScript Web API、数据格式、性能优化等实战内容。',
  canonical,
  prevUrl,
  nextUrl,
  jsonLd: {
    '@context': 'https://schema.org',
    '@type': 'Blog',
    name: '工具盒子技术博客',
    url: normalizeUrlTrailingSlash(`${SITE_URL}/blog`),
    description: '开发者工具的技术原理与最佳实践深度解析',
    publisher: orgEntity,
    author: orgEntity,
    blogPost: allPosts.map((post) => ({
      '@type': 'BlogPosting',
      headline: post.data.title,
      description: post.data.description,
      datePublished: post.data.pubDate.toISOString(),
      url: normalizeUrlTrailingSlash(`${SITE_URL}/blog/${post.id}`),
      keywords: post.data.tags.join(', '),
    })),
  },
};

// 分页页码数组：[1, 2, 3, ..., lastPage]
const pageNumbers = Array.from({ length: page.lastPage }, (_, i) => i + 1);
---

<BaseLayout meta={meta}>
  <section class="container">
    <div class="page-hero">
      <h1>技术博客</h1>
      <p>开发者工具背后的技术原理与最佳实践，每一篇都配套可用的在线工具。</p>
    </div>

    <ul class="blog-list" role="list">
      {posts.map((post) => (
        <li class="blog-card">
          <h2 class="blog-card__title">
            <a href={`/blog/${post.id}`} class="blog-card__link">{post.data.title}</a>
          </h2>
          <p class="blog-card__desc">{post.data.description}</p>
          <div class="blog-card__meta">
            <time datetime={post.data.pubDate.toISOString()}>
              {formatDate(post.data.pubDate)}
            </time>
            {post.data.tags.length > 0 && (
              <span class="blog-card__tags">
                {post.data.tags.map((tag) => (
                  <a href={`/blog/tag/${tagToSlug(tag)}`} class="blog-card__tag">#{tag}</a>
                ))}
              </span>
            )}
          </div>
        </li>
      ))}
    </ul>

    {/* 分页导航：仅多页时显示 */}
    {page.lastPage > 1 && (
      <nav class="pagination" aria-label="博客分页导航">
        {page.url.prev ? (
          <a href={page.url.prev} class="pagination__btn" aria-label="上一页">← 上一页</a>
        ) : (
          <span class="pagination__btn pagination__btn--disabled" aria-hidden="true">← 上一页</span>
        )}

        <ul class="pagination__pages" role="list">
          {pageNumbers.map((num) => (
            <li>
              <a
                href={num === 1 ? '/blog' : `/blog/${num}`}
                class="pagination__page"
                aria-current={num === page.currentPage ? 'page' : undefined}
              >
                {num}
              </a>
            </li>
          ))}
        </ul>

        {page.url.next ? (
          <a href={page.url.next} class="pagination__btn" aria-label="下一页">下一页 →</a>
        ) : (
          <span class="pagination__btn pagination__btn--disabled" aria-hidden="true">下一页 →</span>
        )}
      </nav>
    )}

    <!-- 标签入口：引导用户进入标签索引页 -->
    <div class="blog-tags-entry">
      <a href="/blog/tag" class="btn">按标签浏览全部文章 →</a>
    </div>
  </section>
</BaseLayout>

<style>
  .blog-list {
    list-style: none;
    padding: 0;
    margin: 32px 0 24px;
    display: grid;
    gap: 20px;
  }

  .blog-card {
    position: relative;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    box-shadow: var(--shadow-sm);
    transition: border-color var(--transition-base), box-shadow var(--transition-base),
      transform var(--transition-base);
    overflow: hidden;
    padding: 24px;
  }

  /* 悬停时左侧出现主色指示条，与首页工具卡片视觉风格统一 */
  .blog-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: linear-gradient(180deg, var(--color-primary), var(--color-accent));
    transform: scaleY(0);
    transform-origin: top;
    transition: transform var(--transition-base);
  }

  .blog-card:hover {
    border-color: var(--color-primary);
    /* 与首页 tool-card / blog-section__card 悬停反馈统一：主色光晕 + 上浮 */
    box-shadow: var(--shadow-hover), 0 0 0 3px var(--color-primary-ring);
    transform: translateY(-4px);
  }

  .blog-card:hover::before {
    transform: scaleY(1);
  }

  /* 拉伸链接：标题链接的 ::after 撑满整张卡片，实现"整卡可点击" */
  .blog-card__link {
    color: inherit;
    text-decoration: none;
  }

  .blog-card__link::after {
    content: '';
    position: absolute;
    inset: 0;
  }

  .blog-card__title {
    margin: 0 0 8px;
    font-size: 19px;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .blog-card__desc {
    margin: 0 0 14px;
    color: var(--color-text-soft);
    font-size: 14.5px;
    line-height: 1.7;
  }

  .blog-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
    font-size: 13px;
    color: var(--color-text-muted);
  }

  .blog-card__tags {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  /* 标签链接：z-index 高于拉伸链接，保证可单独点击 */
  .blog-card__tag {
    position: relative;
    z-index: 1;
    color: var(--color-primary);
    background: var(--color-primary-soft);
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 12px;
    text-decoration: none;
    transition: background-color var(--transition-fast);
  }

  .blog-card__tag:hover {
    background: var(--color-primary-ring);
  }

  /* 分页导航：居中布局，按钮与页码统一样式 */
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin: 40px 0 24px;
    flex-wrap: wrap;
  }

  .pagination__pages {
    display: flex;
    list-style: none;
    gap: 4px;
    margin: 0;
    padding: 0;
  }

  .pagination__page,
  .pagination__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 40px;
    height: 40px;
    padding: 0 12px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg);
    color: var(--color-text);
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    transition: border-color var(--transition-fast), background-color var(--transition-fast),
      color var(--transition-fast);
  }

  .pagination__page:hover,
  .pagination__btn:hover {
    border-color: var(--color-primary);
    background: var(--color-primary-soft);
  }

  /* 当前页高亮：主色背景 + 白色文字 */
  .pagination__page[aria-current='page'] {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: #fff;
  }

  /* 禁用状态：不可点击的上一页/下一页按钮 */
  .pagination__btn--disabled {
    opacity: 0.4;
    cursor: not-allowed;
    pointer-events: none;
  }

  /* 标签入口 */
  .blog-tags-entry {
    margin: 32px 0 64px;
    text-align: center;
  }

  @media (max-width: 768px) {
    .blog-card {
      padding: 20px;
    }
    .blog-card__title {
      font-size: 17px;
    }
    /* 移动端分页：缩小尺寸、减少间距 */
    .pagination {
      gap: 8px;
    }
    .pagination__page,
    .pagination__btn {
      min-width: 36px;
      height: 36px;
      padding: 0 8px;
      font-size: 13px;
    }
  }
</style>
