---
import BaseLayout, { type SiteMeta } from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { tagToSlug } from '../../../utils/tags';
import { getSiteUrl } from '../../../utils/site';

// 获取所有文章
const posts = await getCollection('blog');

// 统计每个标签的文章数量，slug → { name, count }
const tagStats = new Map<string, { name: string; count: number }>();
for (const post of posts) {
  for (const tag of post.data.tags) {
    const slug = tagToSlug(tag);
    const existing = tagStats.get(slug);
    if (existing) {
      existing.count += 1;
    } else {
      tagStats.set(slug, { name: tag, count: 1 });
    }
  }
}

// 按文章数量倒序排列，文章数相同的按标签名升序
const tags = Array.from(tagStats.values()).sort((a, b) => {
  if (b.count !== a.count) return b.count - a.count;
  return a.name.localeCompare(b.name, 'zh-CN');
});

// 站点绝对 URL：集中化获取，未配置时构建报错
const SITE_URL = getSiteUrl(Astro.site);

const meta: SiteMeta = {
  title: '全部标签 - 技术博客',
  description: `浏览工具盒子技术博客的全部 ${tags.length} 个标签，按文章数量排序。通过标签快速找到感兴趣的技术主题：JSON、UUID、Base64、Hash、时间戳、URL 等开发者工具相关内容。`,
  canonical: `${SITE_URL}/blog/tag`,
  // 同时声明集合页类型与面包屑结构化数据，帮助搜索引擎理解页面层级
  jsonLd: [
    {
      '@context': 'https://schema.org',
      '@type': 'CollectionPage',
      name: '全部标签 - 工具盒子技术博客',
      description: '技术博客全部标签索引，按文章数量排序',
      url: `${SITE_URL}/blog/tag`,
      isPartOf: {
        '@type': 'Blog',
        name: '工具盒子技术博客',
        url: `${SITE_URL}/blog`,
      },
    },
    {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: '首页', item: SITE_URL },
        { '@type': 'ListItem', position: 2, name: '技术博客', item: `${SITE_URL}/blog` },
        { '@type': 'ListItem', position: 3, name: '全部标签', item: `${SITE_URL}/blog/tag` },
      ],
    },
  ],
};
---
<BaseLayout meta={meta}>
  <section class="container">
    <!-- 面包屑导航 -->
    <nav class="breadcrumb" aria-label="面包屑导航">
      <a href="/blog">博客</a>
      <span aria-hidden="true">/</span>
      <span>全部标签</span>
    </nav>

    <div class="page-hero">
      <h1>全部标签</h1>
      <p>共 {tags.length} 个标签，{posts.length} 篇文章</p>
    </div>

    {tags.length > 0 ? (
      <ul class="tag-cloud" role="list">
        {tags.map((tag) => (
          <li class="tag-item">
            <a href={`/blog/tag/${tagToSlug(tag.name)}`} class="tag-item__link">
              <span class="tag-item__name">#{tag.name}</span>
              <span class="tag-item__count">{tag.count} 篇</span>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <div class="empty-state">
        <p>暂无标签。</p>
        <a class="btn" href="/blog">返回博客列表</a>
      </div>
    )}

    <div class="tag-nav">
      <a class="btn" href="/blog">返回博客列表</a>
    </div>
  </section>
</BaseLayout>

<style>
  .breadcrumb {
    font-size: 13px;
    color: var(--color-text-muted);
    margin: 16px 0;
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .breadcrumb a {
    color: var(--color-primary);
  }

  .breadcrumb a:hover {
    text-decoration: underline;
  }

  .page-hero {
    margin-bottom: 24px;
  }

  .page-hero h1 {
    font-size: 30px;
    margin: 0 0 8px;
    letter-spacing: -0.02em;
    font-weight: 700;
  }

  .page-hero p {
    margin: 0;
    color: var(--color-text-soft);
    font-size: 15px;
  }

  .tag-cloud {
    list-style: none;
    padding: 0;
    margin: 24px 0 32px;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 12px;
  }

  .tag-item__link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 16px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    color: inherit;
    transition: border-color var(--transition-base), box-shadow var(--transition-base),
      transform var(--transition-base);
  }

  .tag-item__link:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-sm);
    transform: translateY(-1px);
  }

  .tag-item__name {
    color: var(--color-primary);
    font-weight: 500;
    font-size: 14.5px;
  }

  .tag-item__count {
    color: var(--color-text-muted);
    font-size: 12.5px;
    background: var(--color-bg-soft);
    padding: 2px 8px;
    border-radius: 999px;
  }

  .empty-state {
    text-align: center;
    padding: 48px 16px;
    color: var(--color-text-soft);
  }

  .empty-state p {
    margin: 0 0 16px;
  }

  .tag-nav {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin: 16px 0 64px;
  }

  @media (max-width: 768px) {
    .page-hero h1 {
      font-size: 24px;
    }
    .tag-cloud {
      grid-template-columns: 1fr;
    }
  }
</style>
