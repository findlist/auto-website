    padding: 4px 6px;
    background: var(--color-bg-soft, #f3f4f6);
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: var(--radius-sm, 4px);
  }

  .exifedit__chunk-filter-label {
    font-size: 12px;
    color: var(--color-text-soft);
    user-select: none;
  }

  .exifedit__chunk-filter-input {
    flex: 1;
    min-width: 0;
    padding: 4px 8px;
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: var(--radius-sm, 4px);
    background: var(--color-bg, #fff);
    color: var(--color-text);
    font-size: 12px;
    font-family: inherit;
    min-height: 28px;
  }

  .exifedit__chunk-filter-input:focus {
    outline: 2px solid var(--color-primary, #3b82f6);
    outline-offset: 1px;
    border-color: var(--color-primary, #3b82f6);
  }

  /* 清除按钮：紧凑圆形 ✕ */
  .exifedit__chunk-filter-clear {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    padding: 0;
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: 50%;
    background: var(--color-bg, #fff);
    color: var(--color-text-soft);
    font-size: 12px;
    line-height: 1;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .exifedit__chunk-filter-clear:hover {
    background: rgba(239, 68, 68, 0.08);
    color: #dc2626;
    border-color: rgba(239, 68, 68, 0.35);
  }

  .exifedit__chunk-filter-clear:focus-visible {
    outline: 2px solid var(--color-primary, #3b82f6);
    outline-offset: 1px;
  }

  /* 匹配数量提示 */
  .exifedit__chunk-filter-count {
    margin: 0;
    padding: 2px 6px;
    font-size: 11px;
    color: var(--color-text-soft);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }

  /* 无匹配空状态 */
  .exifedit__chunk-empty {
    padding: 12px 6px;
    text-align: center;
    font-style: italic;
  }

  .exifedit__chunk-list {
    display: flex;
    flex-direction: column;
    max-height: 360px;
    overflow-y: auto;
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: var(--radius-sm, 4px);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 11px;
  }

  .exifedit__chunk-row {
    display: grid;
    grid-template-columns: 28px 64px 60px 1fr;
    gap: 6px;
    padding: 4px 6px;
    align-items: center;
    border-bottom: 1px solid var(--color-border, #e5e7eb);
  }

  .exifedit__chunk-row:last-child {
    border-bottom: none;
  }

  .exifedit__chunk-row--head {
    position: sticky;
    top: 0;
    background: var(--color-bg-soft, #f3f4f6);
    color: var(--color-text-soft);
    font-weight: 600;
    text-transform: uppercase;
    font-size: 10px;
    letter-spacing: 0.5px;
    z-index: 1;
  }

  .exifedit__chunk-row--critical {
    background: rgba(59, 130, 246, 0.05);
  }

  .exifedit__chunk-row--aux {
    background: transparent;
  }

  /* 可点击的辅助 chunk 行（第 109 轮新增） */
  .exifedit__chunk-row--clickable {
    cursor: pointer;
    transition: background 0.12s;
  }

  .exifedit__chunk-row--clickable:hover {
    background: rgba(37, 99, 235, 0.06);
  }

  .exifedit__chunk-row--clickable:focus-visible {
    outline: 2px solid var(--color-primary, #2563eb);
    outline-offset: -2px;
  }

  /* 已展开的 chunk 行（与 hover 区分，更明显的背景） */
  .exifedit__chunk-row--expanded {
    background: rgba(37, 99, 235, 0.10);
  }

  .exifedit__chunk-row--expanded:hover {
    background: rgba(37, 99, 235, 0.14);
  }

  /* 展开/折叠图标（▶/▼） */
  .exifedit__chunk-toggle {
    display: inline-block;
    width: 12px;
    margin-right: 6px;
    color: var(--color-primary, #2563eb);
    font-size: 10px;
    text-align: center;
    user-select: none;
  }

  /* ============================================================
     chunk hex dump（第 109 轮新增）
     ============================================================ */
  .exifedit__chunk-hex {
    background: var(--color-bg-soft, rgba(0, 0, 0, 0.02));
    border-left: 2px solid var(--color-primary, #2563eb);
    padding: 8px 10px;
    border-bottom: 1px solid var(--color-border, #e5e7eb);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 11px;
    line-height: 1.5;
    overflow-x: auto;
  }

  .exifedit__chunk-hex-pre {
    margin: 0;
    white-space: pre;
    color: var(--color-text);
  }

  .exifedit__chunk-hex-line {
    display: block;
  }

  /* 偏移列：灰色弱化 */
  .exifedit__chunk-hex-offset {
    color: var(--color-text-soft, #6b7280);
  }

  /* hex 字节列：保持默认文字色 */
  .exifedit__chunk-hex-bytes {
    color: var(--color-text);
  }

  /* ASCII 列：使用主色调突出可读字符 */
  .exifedit__chunk-hex-ascii {
    color: var(--color-primary, #2563eb);
  }

  /* 截断提示（橙色警告色） */
  .exifedit__chunk-hex-truncated {
    margin: 6px 0 4px;
    padding: 6px 8px;
    background: rgba(245, 158, 11, 0.10);
    border-left: 2px solid #f59e0b;
    color: #b45309;
    font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
    font-size: 11px;
    border-radius: 2px;
  }

  /* 底部信息提示 */
  .exifedit__chunk-hex-hint {
    margin: 4px 0 0;
    color: var(--color-text-soft, #6b7280);
    font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
    font-size: 10px;
    letter-spacing: 0.2px;
  }

  .exifedit__chunk-cell {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .exifedit__chunk-cell--idx {
    color: var(--color-text-soft);
    text-align: right;
  }

  .exifedit__chunk-cell--type {
    display: flex;
    align-items: center;
  }

  .exifedit__chunk-cell--size {
    text-align: right;
    color: var(--color-text-soft);
  }

  .exifedit__chunk-cell--summary {
    color: var(--color-text);
    white-space: normal;
    word-break: break-all;
    font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
  }

  .exifedit__chunk-badge {
    display: inline-block;
    padding: 2px 6px;
    border-radius: var(--radius-sm, 4px);
    font-size: 10px;
    font-weight: 600;
    background: rgba(107, 114, 128, 0.12);
    color: var(--color-text-soft);
    border: 1px solid rgba(107, 114, 128, 0.25);
  }

  .exifedit__chunk-badge--critical {
    background: rgba(59, 130, 246, 0.12);
    color: #1d4ed8;
    border-color: rgba(59, 130, 246, 0.35);
  }

  /* ============================================================
     Tab 切换：单文件 / 批量处理（第 89 轮新增）
     ============================================================ */
  .exifedit__tabs {
    display: flex;
    gap: 4px;
    padding: 4px;
    background: var(--color-bg-soft, #f3f4f6);
    border-radius: var(--radius-md, 8px);
    border: 1px solid var(--color-border, #e5e7eb);
  }

  .exifedit__tab {
    flex: 1;
    padding: 10px 16px;
    border: none;
    background: transparent;
    color: var(--color-text-soft, #6b7280);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    border-radius: var(--radius-sm, 4px);
    transition: background 0.15s, color 0.15s;
    min-height: 44px; /* WCAG 2.2 触控目标最小尺寸 */
  }

  .exifedit__tab:hover:not(.exifedit__tab--active) {
    color: var(--color-text);
    background: rgba(255, 255, 255, 0.5);
  }

  .exifedit__tab--active {
    background: var(--color-bg, #fff);
    color: var(--color-primary, #2563eb);
    font-weight: 600;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.06);
  }

  .exifedit__tab:focus-visible {
    outline: 2px solid var(--color-primary, #2563eb);
    outline-offset: 2px;
  }

  /* ============================================================
     批量处理面板（exifedit__batch__ 命名空间）
     ============================================================ */
  .exifedit__batch {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 16px;
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: var(--radius-md, 8px);
    background: var(--color-bg, #fff);
  }

  .exifedit__batch-ops-summary {
    padding: 12px;
    background: var(--color-bg-soft, #f9fafb);
    border-radius: var(--radius-sm, 4px);
  }

  .exifedit__batch-ops-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .exifedit__batch-ops-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--color-text);
  }

  .exifedit__batch-ops-icon {
    color: #059669;
    font-weight: bold;
  }

  .exifedit__batch-ops-detail {
    color: var(--color-text-soft);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 12px;
  }

  /* 批量上传区：在原 dropzone 基础上稍微突出 */
  .exifedit__dropzone--batch {
    padding: 24px 16px;
  }

  /* 批量文件列表 */
  .exifedit__batch-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .exifedit__batch-list-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .exifedit__batch-list-header .exifedit__section-title {
    margin: 0;
    border: none;
    padding: 0;
  }

  .exifedit__batch-files {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
    max-height: 320px;
    overflow-y: auto;
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: var(--radius-sm, 4px);
  }

  .exifedit__batch-file {
    display: grid;
    grid-template-columns: 1fr auto 32px;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    font-size: 12px;
    border-bottom: 1px solid var(--color-border, #f3f4f6);
  }

  .exifedit__batch-file:last-child {
    border-bottom: none;
  }

  .exifedit__batch-file-name {
    color: var(--color-text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .exifedit__batch-file-size {
    color: var(--color-text-soft, #6b7280);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }

  .exifedit__batch-file-remove {
    width: 28px;
    height: 28px;
    border: none;
    background: transparent;
    color: var(--color-text-soft, #6b7280);
    font-size: 18px;
    line-height: 1;
    cursor: pointer;
    border-radius: var(--radius-sm, 4px);
    transition: background 0.15s, color 0.15s;
  }

  .exifedit__batch-file-remove:hover:not(:disabled) {
    background: rgba(220, 38, 38, 0.08);
    color: #b91c1c;
  }

  .exifedit__batch-file-remove:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  /* 批量处理结果 */
  .exifedit__batch-result {
    padding: 12px;
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: var(--radius-md, 8px);
    background: var(--color-bg, #fff);
  }

  .exifedit__batch-result .exifedit__summary {
    grid-template-columns: repeat(3, 1fr);
  }

  .exifedit__summary-value--bad {
    color: #b91c1c;
  }

  .exifedit__batch-items {
    list-style: none;
    margin: 12px 0 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
    max-height: 400px;
    overflow-y: auto;
  }

  .exifedit__batch-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 6px 10px;
    border-left: 3px solid transparent;
    font-size: 12px;
  }

  .exifedit__batch-item--success {
    border-left-color: #059669;
    background: rgba(5, 150, 105, 0.04);
  }

  .exifedit__batch-item--skipped {
    border-left-color: #d97706;
    background: rgba(217, 119, 6, 0.04);
  }

  .exifedit__batch-item--error {
    border-left-color: #b91c1c;
    background: rgba(220, 38, 38, 0.04);
  }

  .exifedit__batch-item-name {
    color: var(--color-text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-weight: 500;
  }

  .exifedit__batch-item-status {
    color: var(--color-text-soft, #6b7280);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 11px;
  }

  /* ============================================================
     预设管理面板（exifedit__preset__ 命名空间）
     ============================================================ */
  .exifedit__presets {
    padding: 16px;
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: var(--radius-md, 8px);
    background: var(--color-bg, #fff);
  }

  .exifedit__preset-save {
    display: flex;
    gap: 8px;
    margin-top: 8px;
  }

  .exifedit__preset-name-input {
    flex: 1;
    min-width: 0;
    padding: 8px 12px;
    border: 1px solid var(--color-border, #d1d5db);
    border-radius: var(--radius-sm, 4px);
    font-size: 13px;
    background: var(--color-bg, #fff);
    color: var(--color-text);
  }

  .exifedit__preset-name-input:focus {
    border-color: var(--color-primary, #2563eb);
    outline: none;
    box-shadow: 0 0 0 2px rgba(37, 99, 235, 0.15);
  }

  .exifedit__preset-list {
    list-style: none;
    margin: 12px 0 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .exifedit__preset-item {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 12px;
    padding: 10px 12px;
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: var(--radius-sm, 4px);
    background: var(--color-bg-soft, #f9fafb);
  }

  .exifedit__preset-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .exifedit__preset-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .exifedit__preset-ops {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .exifedit__preset-op-tag {
    display: inline-flex;
    align-items: center;
    padding: 2px 8px;
    border-radius: var(--radius-sm, 4px);
    background: rgba(37, 99, 235, 0.08);
    color: #1d4ed8;
    font-size: 11px;
  }

  .exifedit__preset-meta {
    font-size: 11px;
    color: var(--color-text-soft, #6b7280);
  }

  .exifedit__preset-actions {
    display: flex;
    flex-direction: column;
    gap: 4px;
    align-items: stretch;
  }

  .exifedit__btn--small {
    padding: 4px 10px;
    font-size: 12px;
    min-height: 28px;
  }

  .exifedit__btn--danger {
    color: #b91c1c;
    border-color: rgba(220, 38, 38, 0.3);
  }

  .exifedit__btn--danger:hover:not(:disabled) {
    background: rgba(220, 38, 38, 0.08);
    border-color: #b91c1c;
  }

  .exifedit__preset-io {
    display: flex;
    gap: 8px;
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px dashed var(--color-border, #e5e7eb);
  }

  .exifedit__preset-io .exifedit__btn {
    flex: 1;
  }

  .exifedit__hint--muted {
    color: var(--color-text-soft, #9ca3af);
    font-style: italic;
  }

  /* ============================================================
     响应式：768px 单列堆叠
     ============================================================ */
  @media (max-width: 768px) {
    .exifedit__main {
      grid-template-columns: 1fr;
    }

    .exifedit__summary {
      grid-template-columns: repeat(2, 1fr);
    }

    .exifedit__compare-grid {
      grid-template-columns: 1fr;
    }

    .exifedit__preview-imgs {
      grid-template-columns: 1fr;
    }

    .exifedit__preview-item img {
      max-height: 200px;
    }

    /* chunk 列表：移动端紧凑布局，缩小列宽 */
    .exifedit__chunk-row {
      grid-template-columns: 22px 52px 48px 1fr;
      gap: 4px;
      padding: 3px 4px;
      font-size: 10px;
    }

    .exifedit__chunk-list {
      max-height: 280px;
    }

    /* chunk 搜索过滤：移动端紧凑尺寸 */
    .exifedit__chunk-filter-input {
      font-size: 11px;
      padding: 3px 6px;
      min-height: 24px;
    }

    .exifedit__chunk-filter-clear {
      width: 22px;
      height: 22px;
      font-size: 11px;
    }

    /* chunk hex dump：移动端横向滚动，字号略小 */
    .exifedit__chunk-hex {
      padding: 6px 8px;
      font-size: 10px;
    }

    .exifedit__chunk-hex-truncated,
    .exifedit__chunk-hex-hint {
      font-size: 10px;
    }

    /* Tab：移动端紧凑显示，单行文本 */
    .exifedit__tab {
      padding: 10px 8px;
      font-size: 12px;
    }

    /* 批量结果摘要：移动端两列 */
    .exifedit__batch-result .exifedit__summary {
      grid-template-columns: repeat(2, 1fr);
    }

    /* 预设项：移动端单列堆叠，操作按钮横向 */
    .exifedit__preset-item {
      grid-template-columns: 1fr;
    }

    .exifedit__preset-actions {
      flex-direction: row;
    }

    .exifedit__preset-actions .exifedit__btn {
      flex: 1;
    }
  }

  /* ============================================================
     响应式：414px 紧凑布局
     ============================================================ */
  @media (max-width: 414px) {
    .exifedit__dropzone {
      padding: 20px 12px;
    }

    .exifedit__dropzone-icon {
      font-size: 28px;
    }

    .exifedit__summary {
      grid-template-columns: 1fr;
    }

    .exifedit__summary-item {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }

    .exifedit__snap-field {
      grid-template-columns: 1fr;
      gap: 2px;
    }

    .exifedit__actions .exifedit__btn {
      flex: 1;
      min-width: 0;
    }

    /* 批量结果摘要：紧凑单列 */
    .exifedit__batch-result .exifedit__summary {
      grid-template-columns: 1fr;
    }

    /* 预设保存输入与按钮堆叠 */
    .exifedit__preset-save {
      flex-direction: column;
    }

    /* 预设导入导出按钮堆叠 */
    .exifedit__preset-io {
      flex-direction: column;
    }
  }

  /* ============================================================
     暗色模式适配
     ============================================================ */
  @media (prefers-color-scheme: dark) {
    .exifedit__dropzone {
      background: rgba(255, 255, 255, 0.02);
    }

    .exifedit__ops,
    .exifedit__result,
    .exifedit__compare,
    .exifedit__chunks {
      background: #1f2937;
    }

    /* chunk 列表暗色 */
    .exifedit__chunk-list {
      border-color: rgba(255, 255, 255, 0.1);
    }

    .exifedit__chunk-row {
      border-bottom-color: rgba(255, 255, 255, 0.06);
    }

    .exifedit__chunk-row--head {
      background: rgba(255, 255, 255, 0.06);
      color: #cbd5e1;
    }

    .exifedit__chunk-row--critical {
      background: rgba(59, 130, 246, 0.12);
    }

    .exifedit__chunk-badge {
      background: rgba(255, 255, 255, 0.08);
      color: #cbd5e1;
      border-color: rgba(255, 255, 255, 0.15);
    }

    .exifedit__chunk-badge--critical {
      background: rgba(59, 130, 246, 0.2);
      color: #93c5fd;
      border-color: rgba(59, 130, 246, 0.4);
    }

    /* chunk 搜索过滤暗色 */
    .exifedit__chunk-filter {
      background: rgba(255, 255, 255, 0.04);
      border-color: rgba(255, 255, 255, 0.1);
    }

    .exifedit__chunk-filter-input {
      background: #1f2937;
      color: #e5e7eb;
      border-color: rgba(255, 255, 255, 0.1);
    }

    .exifedit__chunk-filter-input::placeholder {
      color: #6b7280;
    }

    .exifedit__chunk-filter-clear {
      background: #1f2937;
      color: #9ca3af;
      border-color: rgba(255, 255, 255, 0.15);
    }

    .exifedit__chunk-filter-clear:hover {
      background: rgba(239, 68, 68, 0.15);
      color: #fca5a5;
      border-color: rgba(239, 68, 68, 0.4);
