---
import BaseLayout, { type SiteMeta } from '../layouts/BaseLayout.astro';
import FindReplaceTool from '../components/FindReplaceTool.tsx';

const meta: SiteMeta = {
  title: '字符替换工具 - 在线查找替换 / 正则替换 / 批量替换',
  description:
    '在线字符替换工具：支持普通文本与正则表达式两种模式，正则支持 g/m/i 标志与 $1/$& 捕获组引用，实时统计替换次数。全本地处理，零广告零追踪。',
  jsonLd: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: '字符替换工具',
    description: '在线查找替换工具，支持普通文本与正则表达式两种模式，可选大小写敏感与全局替换。',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Any (Web Browser)',
    inLanguage: 'zh-CN',
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'CNY',
    },
  },
};
---
<BaseLayout meta={meta}>
  <section class="container">
    <div class="page-hero page-hero--tool">
      <h1>字符替换工具</h1>
      <p>
        支持普通文本替换与正则表达式替换两种模式。普通模式字面量匹配可选大小写敏感，
        正则模式支持 g/m/i 标志与 $1、$& 等捕获组引用。实时统计替换次数与结果字符数。
        适用于批量改名、模板填充、日志脱敏、CSV 字段替换、代码重构等场景。所有处理在浏览器本地完成。
      </p>
    </div>

    <FindReplaceTool client:load />

    <section class="json-faq" aria-labelledby="faq-title">
      <h2 id="faq-title">常见问题</h2>
      <details>
        <summary>普通文本替换和正则表达式替换有什么区别？</summary>
        <p>
          <strong>普通文本替换</strong>（字面量匹配）将查找串作为普通字符串处理，不解析其中的正则特殊字符。
          例如查找 <code>"."</code> 会匹配字面的句点字符，而不是正则中的"任意字符"。
          适合简单的文本替换、批量改名等不需要复杂匹配的场景。
          <strong>正则表达式替换</strong>支持完整的正则语法，可以匹配模式（如
          <code>\d{4}-\d{2}-\d{2}</code> 匹配日期）、使用捕获组引用（如 <code>$1</code>），
          适合日志脱敏、格式转换、代码重构等复杂替换场景。
        </p>
      </details>
      <details>
        <summary>正则替换中 $1、$&amp; 等捕获组引用如何使用？</summary>
        <p>
          在正则替换模式下，替换字符串支持以下特殊替换串：
          <code>$1</code>、<code>$2</code> … 引用第 n 个捕获组（括号匹配的内容）；
          <code>$&amp;</code> 引用整个匹配的子串；
          <code>$`</code> 引用匹配项左侧的文本；
          <code>$'</code> 引用匹配项右侧的文本；
          <code>$$</code> 表示字面的 <code>$</code>。
          例如把 <code>"2026-07-11"</code> 替换为 <code>"07/11/2026"</code>，
          可用正则 <code>(\d{4})-(\d{2})-(\d{2})</code> 配合替换串 <code>$2/$3/$1</code>。
        </p>
      </details>
      <details>
        <summary>关闭全局替换 (g) 标志后会发生什么？</summary>
        <p>
          全局替换标志 <code>g</code> 控制是否替换所有匹配项。开启 <code>g</code> 时，
          从文本开头到结尾替换所有匹配项；关闭 <code>g</code> 时，仅替换第一个匹配项，
          其余匹配项保持不变。例如对 <code>"a-b-c"</code> 用正则 <code>-</code> 替换为
          <code>"_"</code>：开启 <code>g</code> 结果为 <code>"a_b_c"</code>，
          关闭 <code>g</code> 结果为 <code>"a_b-c"</code>。
        </p>
      </details>
      <details>
        <summary>大小写不敏感替换是如何实现的？</summary>
        <p>
          普通模式下，大小写不敏感通过将原文与查找串都转为小写后比较边界实现，
          替换时仍保留原文大小写格式。正则模式下，大小写不敏感通过 <code>i</code> 标志实现，
          这是 JavaScript 正则引擎原生支持的标志，匹配时忽略大小写差异。
          例如查找 <code>"hello"</code> 并开启忽略大小写，会同时匹配
          <code>"Hello"</code>、<code>"HELLO"</code>、<code>"hElLo"</code> 等。
        </p>
      </details>
      <details>
        <summary>这个工具适合哪些使用场景？</summary>
        <p>
          ① <strong>批量改名</strong>：统一替换文件名列表中的特定字符串；
          ② <strong>模板填充</strong>：将模板中的占位符替换为实际内容；
          ③ <strong>日志脱敏</strong>：用正则匹配手机号、邮箱、身份证号等敏感信息并替换为掩码；
          ④ <strong>CSV 字段替换</strong>：批量修改 CSV 数据中的字段值；
          ⑤ <strong>代码重构</strong>：重命名变量、修改 API 调用、统一命名风格；
          ⑥ <strong>格式转换</strong>：日期格式、分隔符、大小写风格等格式互转。
        </p>
      </details>
      <details>
        <summary>多行模式 (m) 标志有什么作用？</summary>
        <p>
          多行模式 <code>m</code> 改变 <code>^</code> 和 <code>$</code> 的匹配行为。
          默认情况下，<code>^</code> 匹配整个字符串的开头，<code>$</code> 匹配整个字符串的结尾。
          开启 <code>m</code> 后，<code>^</code> 匹配每行的开头，<code>$</code> 匹配每行的结尾。
          例如对多行文本用正则 <code>^TODO:</code> 查找行首的待办标记，
          需要开启 <code>m</code> 才能匹配每一行开头，否则只匹配整个文本的开头。
        </p>
      </details>
      <details>
        <summary>数据会上传到服务器吗？</summary>
        <p>
          不会。本工具完全在浏览器内运行，所有查找与替换处理由 JavaScript 在你本地执行，
          不会发送任何输入文本或替换结果到服务器。全程零网络请求，可离线使用，
          适合处理包含敏感信息的日志、配置文件、个人数据等。
        </p>
      </details>
    </section>

    <!-- 相关工具：文本处理矩阵内链，提升站内导航与 SEO 内链结构 -->
    <section class="related-tools" aria-labelledby="related-title">
      <h2 id="related-title">相关工具</h2>
      <ul class="related-tools__list">
        <li><a href="/lorem">占位文本生成器</a> —— Lorem Ipsum 与 Mock 假数据</li>
        <li><a href="/text-analyzer">文本统计分析</a> —— 字数词数统计与关键词频率</li>
        <li><a href="/text-case">文本大小写转换</a> —— 10 种命名风格互转</li>
        <li><a href="/text-dedup">文本去重</a> —— 按行去重与重复行清理</li>
        <li><a href="/sort">文本排序</a> —— 8 种排序模式与随机打乱</li>
        <li><a href="/random-picker">随机选择器</a> —— 加密级随机抽取 N 项</li>
        <li><a href="/slug">URL Slug 生成器</a> —— 文章标题转 URL 友好 slug</li>
        <li><a href="/reverse">文本反转</a> —— 字符/行/单词三种反转模式</li>
        <li><a href="/truncate">文本截断</a> —— 按字符/字节/行数截断</li>
        <li><a href="/text-similarity">文本相似度</a> —— Levenshtein 距离与 Jaccard 相似度</li>
      </ul>
    </section>

    <!-- 相关博客：工具页反向内链，引导用户深度阅读（脚本批量生成，请勿手动修改） -->
    <section class="related-blogs" aria-labelledby="related-blogs-title">
      <h2 id="related-blogs-title">相关博客</h2>
      <ul class="related-blogs__list">
        <li>
          <a href="/blog/find-replace-guide">字符替换实战指南：从普通文本到正则表达式的查找替换</a><span class="related-blogs__desc">系统讲解字符替换的两种模式：普通文本字面量替换与正则表达式替换。深入分析 $1、$&amp; 等捕获组引用的原理，对比 g/m/i 正则标志的作用，覆盖日志脱敏、批量改名、模板填充、…</span>
        </li>
      </ul>
    </section>
  </section>
</BaseLayout>

<style is:global>
  /* 字符替换工具专属样式 */
  .fr {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .fr__input-section,
  .fr__result-section {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .fr__toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }

  .fr__label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text);
  }

  .fr__stat {
    font-size: 13px;
    font-weight: 400;
    color: var(--color-text-soft);
  }

  .fr__actions {
    display: flex;
    gap: 8px;
  }

  .fr__textarea {
    width: 100%;
    min-height: 160px;
    max-height: 400px;
    padding: 14px 16px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 14px;
    line-height: 1.6;
    resize: vertical;
    transition: border-color var(--transition-fast, 0.15s);
  }

  .fr__textarea:focus {
    outline: none;
    border-color: var(--color-primary, #2b6cff);
    box-shadow: var(--focus-ring, 0 0 0 3px rgba(43, 108, 255, 0.15));
  }

  /* 配置区 */
  .fr__config {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* 查找替换输入对：查找框 + 交换按钮 + 替换框 */
  .fr__pair {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: end;
    gap: 8px;
  }

  .fr__field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .fr__field-label {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text-soft);
  }

  .fr__input {
    width: 100%;
    padding: 10px 14px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 14px;
    transition: border-color var(--transition-fast, 0.15s);
  }

  .fr__input:focus {
    outline: none;
    border-color: var(--color-primary, #2b6cff);
    box-shadow: var(--focus-ring, 0 0 0 3px rgba(43, 108, 255, 0.15));
  }

  /* 交换按钮：垂直居中对齐输入框 */
  .fr__swap {
    height: 38px;
    line-height: 1;
    font-size: 18px;
    padding: 0 12px;
  }

  .fr__fieldset {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 16px;
    padding: 12px 14px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-soft, rgba(0, 0, 0, 0.03));
    margin: 0;
  }

  .fr__legend {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text-soft);
    padding: 0 4px;
  }

  .fr__radio,
  .fr__check {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    color: var(--color-text);
    cursor: pointer;
  }

  .fr__radio input,
  .fr__check input {
    cursor: pointer;
  }

  /* 错误提示 */
  .fr__error {
    padding: 10px 14px;
    background: var(--color-danger-soft, rgba(220, 53, 69, 0.08));
    border-radius: var(--radius-sm);
    color: var(--color-danger, #dc3545);
    font-size: 14px;
  }

  /* 统计区：2 列网格 */
  .fr__stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  .fr__stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 12px 8px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-soft, rgba(0, 0, 0, 0.03));
  }

  .fr__stat-num {
    font-size: 22px;
    font-weight: 700;
    color: var(--color-text);
    font-family: var(--font-mono);
  }

  .fr__stat-label {
    font-size: 12px;
    color: var(--color-text-soft);
  }

  /* 结果展示区 */
  .fr__result {
    width: 100%;
    min-height: 120px;
    max-height: 400px;
    overflow: auto;
    padding: 14px 16px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-soft, rgba(0, 0, 0, 0.03));
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 14px;
    line-height: 1.6;
    white-space: pre-wrap;
    word-break: break-all;
  }

  .fr__result-empty {
    color: var(--color-text-soft);
    font-style: italic;
  }

  /* 状态条 */
  .fr__notice {
    padding: 10px 14px;
    background: var(--color-success-soft, rgba(26, 170, 85, 0.08));
    border-radius: var(--radius-sm);
    color: var(--color-success, #1aaa55);
  }

  .fr__hint {
    padding: 10px 14px;
    color: var(--color-text-soft);
  }

  /* 暗色模式适配 */
  @media (prefers-color-scheme: dark) {
    .fr__textarea,
    .fr__result,
    .fr__fieldset,
    .fr__stat-item,
    .fr__input {
      background: rgba(255, 255, 255, 0.04);
    }
  }

  /* 移动端响应式 */
  @media (max-width: 768px) {
    .fr__pair {
      grid-template-columns: 1fr;
    }
    .fr__swap {
      justify-self: center;
      transform: rotate(90deg);
    }
    .fr__stats {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 414px) {
    .fr__toolbar {
      flex-direction: column;
      align-items: stretch;
    }
    .fr__actions {
      justify-content: flex-end;
    }
  }
</style>
