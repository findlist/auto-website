---
import BaseLayout, { type SiteMeta } from '../layouts/BaseLayout.astro';
import TextAnalyzerTool from '../components/TextAnalyzerTool.tsx';

const meta: SiteMeta = {
  title: '文本统计分析工具 - 字数统计 / 阅读时间 / 关键词频率',
  description:
    '免费的在线文本统计分析工具：实时计算字符数、词数、行数、段落数、句子数，支持中英文混合统计，估算阅读时间，分析关键词频率 Top 10。适用于文章字数统计、SEO 内容长度检查、稿费计算、排版规划。所有数据在浏览器本地处理，零上传、零追踪、零广告。',
  jsonLd: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: '文本统计分析工具',
    description: '在线文本统计分析工具，支持字符数、词数、行数、段落数、句子数、阅读时间估算与关键词频率分析，中英文混合统计。',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Any (Web Browser)',
    inLanguage: 'zh-CN',
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'CNY',
    },
  },
};
---
<BaseLayout meta={meta}>
  <section class="container">
    <div class="page-hero page-hero--tool">
      <h1>文本统计分析工具</h1>
      <p>
        实时统计文本的字符数、词数、行数、段落数、句子数，支持中英文混合分析，
        估算阅读时间，提取关键词频率 Top 10。适用于文章字数统计、SEO 内容长度检查、
        稿费计算、排版规划等场景。所有计算在浏览器本地完成，零上传、零追踪。
      </p>
    </div>

    <TextAnalyzerTool client:load />

    <section class="json-faq" aria-labelledby="faq-title">
      <h2 id="faq-title">常见问题</h2>
      <details>
        <summary>中文字数和英文字数是怎么计算的？</summary>
        <p>
          中文文本按"字"计数，每个汉字算一个字；英文文本按"词"计数，连续的字母序列算一个词。
          例如"Hello 世界"的统计结果为：中文字符 2 个，英文单词 1 个，总词数 3（1 个英文词 + 2 个中文字）。
          这种混合统计方式符合中文排版习惯（按字数计费）和英文写作习惯（按词数计费）。
        </p>
      </details>
      <details>
        <summary>阅读时间是怎么估算的？</summary>
        <p>
          中文阅读速度按每分钟 300 字估算（成年人平均阅读速度），英文阅读速度按每分钟 200 词估算。
          工具会分别计算中英文的阅读时间，取较长者作为最终结果。
          这只是粗略估算，实际阅读速度因内容难度、读者习惯而异——技术文档通常比小说慢 2-3 倍。
        </p>
      </details>
      <details>
        <summary>关键词频率分析是怎么工作的？</summary>
        <p>
          英文文本按空格和标点分词，转为小写后过滤常见停用词（the、a、is 等），
          统计剩余单词的出现频率。中文文本采用 2 字滑窗提取连续词组（bigram），
          统计频率。仅显示出现 ≥ 2 次的关键词，按频率降序排列，最多显示 Top 10。
          注意：中文 bigram 是简单的统计方法，不是真正的分词，结果仅供参考。
        </p>
      </details>
      <details>
        <summary>这个工具适合哪些使用场景？</summary>
        <p>
          ① <strong>文章字数统计</strong>：计算中英文混排文章的总字数，用于稿费计算、字数限制检查；
          ② <strong>SEO 内容优化</strong>：检查 Meta Description（建议 ≤ 160 字符）、Title 标签（建议 ≤ 60 字符）的长度；
          ③ <strong>阅读体验评估</strong>：估算文章阅读时间，判断是否需要分段或精简；
          ④ <strong>关键词密度分析</strong>：检查关键词出现频率，避免堆砌或不足；
          ⑤ <strong>排版规划</strong>：根据段落数和行数估算版面占用。
        </p>
      </details>
      <details>
        <summary>字符数统计包含哪些内容？</summary>
        <p>
          总字符数包含文本中的所有字符（含空格、换行、标点）。不含空格字符数则排除了空格、制表符和换行符。
          另外还细分统计中文字符、英文字母、数字字符和标点符号的数量，方便做精确的内容分析。
          注意：Emoji 表情按 Unicode 码点计数，一个 Emoji 通常算 1-2 个字符（含变体选择符时为 2 个）。
        </p>
      </details>
      <details>
        <summary>数据会上传到服务器吗？</summary>
        <p>
          不会。本工具完全在浏览器内运行，所有统计分析由 JavaScript 在你本地执行，
          不会发送任何输入文本或统计结果到服务器。全程零网络请求，可离线使用。
          适合分析敏感内容（如合同草稿、未公开文章）。
        </p>
      </details>
      <details>
        <summary>段落数和句子数是怎么定义的？</summary>
        <p>
          段落由空行（一个或多个连续空行）分隔，非空的文本块算一个段落。
          句子由句末标点（中文的 。！？ 和英文的 .!? ）分隔，标点后的非空文本算一个新句子。
          注意：英文缩写中的点（如 "Mr." "U.S.A."）会被误判为句子边界，
          这是简单分句的已知限制，复杂场景需要 NLP 分句器。
        </p>
      </details>
    </section>
  </section>
</BaseLayout>

<style is:global>
  /* 文本统计分析工具专属样式 */
  .text-analyzer {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* 输入区 */
  .text-analyzer__input-section {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .text-analyzer__toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }

  .text-analyzer__label {
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text);
  }

  .text-analyzer__actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .text-analyzer__btn {
    padding: 7px 16px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg);
    color: var(--color-text);
    font-size: 14px;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
  }

  .text-analyzer__btn:hover:not(:disabled) {
    border-color: var(--color-primary, #2b6cff);
    color: var(--color-primary, #2b6cff);
  }

  .text-analyzer__btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .text-analyzer__btn--primary {
    background: var(--color-primary, #2b6cff);
    color: #fff;
    border-color: var(--color-primary, #2b6cff);
    font-weight: 500;
  }

  .text-analyzer__btn--primary:hover:not(:disabled) {
    color: #fff;
    opacity: 0.9;
  }

  .text-analyzer__textarea {
    width: 100%;
    min-height: 200px;
    max-height: 500px;
    padding: 14px 16px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    color: var(--color-text);
    font-family: var(--font-mono, ui-monospace, SFMono-Regular, Menlo, monospace);
    font-size: 14px;
    line-height: 1.6;
    resize: vertical;
    transition: border-color 0.15s;
  }

  .text-analyzer__textarea:focus {
    outline: none;
    border-color: var(--color-primary, #2b6cff);
    box-shadow: 0 0 0 3px rgba(43, 108, 255, 0.15);
  }

  /* 结果区 */
  .text-analyzer__results {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* 核心指标卡片网格 */
  .text-analyzer__metrics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 12px;
  }

  .text-analyzer__metric {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 18px 12px;
    background: var(--color-bg-soft, rgba(0, 0, 0, 0.03));
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-align: center;
  }

  .text-analyzer__metric-value {
    font-size: 24px;
    font-weight: 700;
    color: var(--color-primary, #2b6cff);
    font-variant-numeric: tabular-nums;
    line-height: 1.2;
  }

  .text-analyzer__metric-label {
    font-size: 13px;
    color: var(--color-text-soft);
  }

  /* 详细统计区 */
  .text-analyzer__detail-grid {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .text-analyzer__section-title {
    font-size: 16px;
    font-weight: 600;
    color: var(--color-text);
    margin: 0;
    padding-bottom: 6px;
    border-bottom: 1px solid var(--color-border);
  }

  .text-analyzer__detail-table {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 8px;
  }

  .text-analyzer__detail-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 14px;
    background: var(--color-bg-soft, rgba(0, 0, 0, 0.03));
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
  }

  .text-analyzer__detail-label {
    font-size: 14px;
    color: var(--color-text-soft);
  }

  .text-analyzer__detail-value {
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text);
    font-variant-numeric: tabular-nums;
  }

  /* 关键词频率 */
  .text-analyzer__empty {
    font-size: 14px;
    color: var(--color-text-soft);
    padding: 16px;
    text-align: center;
    background: var(--color-bg-soft, rgba(0, 0, 0, 0.03));
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-md);
    margin: 0;
  }

  .text-analyzer__keywords {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .text-analyzer__keyword-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 6px 0;
  }

  .text-analyzer__keyword-word {
    min-width: 80px;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text);
  }

  .text-analyzer__keyword-bar {
    flex: 1;
    height: 8px;
    min-width: 40px;
    background: var(--color-primary, #2b6cff);
    border-radius: 4px;
    opacity: 0.7;
    transition: width 0.3s ease;
  }

  .text-analyzer__keyword-count {
    min-width: 32px;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text-soft);
    text-align: right;
    font-variant-numeric: tabular-nums;
  }

  /* 暗色模式适配 */
  @media (prefers-color-scheme: dark) {
    .text-analyzer__metric,
    .text-analyzer__detail-row,
    .text-analyzer__textarea {
      background: rgba(255, 255, 255, 0.04);
    }
  }

  /* 移动端响应式 */
  @media (max-width: 768px) {
    .text-analyzer__toolbar {
      flex-direction: column;
      align-items: stretch;
    }
    .text-analyzer__actions {
      justify-content: flex-end;
    }
    .text-analyzer__metric-value {
      font-size: 20px;
    }
    .text-analyzer__keyword-word {
      min-width: 60px;
      font-size: 13px;
    }
  }

  @media (max-width: 414px) {
    .text-analyzer__metrics-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .text-analyzer__detail-table {
      grid-template-columns: 1fr;
    }
  }
</style>
